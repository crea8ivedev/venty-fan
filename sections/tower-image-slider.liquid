<!--Start tower-image-slider  -->

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}


<div class="tower-image-slider-main section-{{ section.id }}-padding" style="background-color:{{ section.settings.background }};">


{% if section.settings.heading != blank %}<h3 class="title hxl" style="color:{{ section.settings.color }};text-align:center;">{{ section.settings.heading }}</h3>{% endif %}
<div class="responsive-image">
{%- for block in section.blocks -%}
<div class="tower-image-slider-part" style="color:{{ block.settings.textcolor }};">  

  
{%- if block.settings.image -%}
{% assign  alt = block.settings.image.alt %}
 <img src="{{ block.settings.image| img_url: 'original' }}" alt="{{ alt }}">
{%- endif %}
{% if block.settings.heading != blank %}
 <div class="text">
  {{ block.settings.heading }} 
 </div>
   
  {% endif %}
  
</div>
{%- endfor -%}
</div>




</div>
<!--End tower-image-slider  -->
{% schema %}
  {
    "name": "Tower Image Slider",
    "settings": [
      {
        "type": "inline_richtext",
        "id":"heading",
        "label":"Heading"
      },
      {
        "type": "color",
        "id":"color",
        "label": "Color"
      },
      {
        "type": "color",
        "id":"background",
        "label": "Background"
      },
      {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
       
    ],
    "blocks": [
      {
       "type": "block",
        "name":"Block",
        "settings": [
          {
            "type": "image_picker",
            "id":"image",
            "label":"Image"
          },
          {
            "type": "richtext",
            "id":"heading",
            "label":"Heading"
          },
          {
           "type": "color",
           "id":"textcolor",
           "label": "Heading Color"
          }
        ]
      }
    ],
    "presets": [
     {
       "name":"Tower Image Slider"
     }
    ]
  }
{% endschema %}