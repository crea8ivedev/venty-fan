
<!-- Start custom-2image-section  -->

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background }};
       height:{{section.settings.heightcstmdesktop}}vh;
    
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  
  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mob }}px;
      padding-bottom: {{ section.settings.padding_bottom_mob }}px;
       height:{{section.settings.mobheightcstm}}vh;
    }
  }
{%- endstyle -%}

<style>
  .two-images-only img {
    width: 50%;
    height: 100%;
    object-fit:cover;
}
.two-images-only {
    display: flex;
}
  @media(max-width:768px){
    .two-images-only img:nth-child(2) {
    display: none;
}
     .two-images-only img {
    width: 100%;
}
  }
</style>
   
   <div class="section-{{ section.id }}-padding two-images-only">
 {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
{%- capture sizes -%}
(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
(min-width: 750px) calc((100vw - 130px) / 1), calc((100vw - 50px) / 1)
{%- endcapture -%}

   

     
{% if section.settings.image1 != blank %}
  {% assign alt = section.settings.image1.alt %}
{{
section.settings.image1
| image_url: width: 1500
| image_tag: sizes: sizes, widths: widths,alt:alt

}}

         {% endif %}
   {% if section.settings.image2 != blank %}
 {% assign alt2 = section.settings.image2.alt %}
  {{
section.settings.image2
| image_url: width: 1500
| image_tag: sizes: sizes, widths: widths,alt:alt2

}}   
         {% endif %}
</div>

<!-- End custom-2image-section  -->       
{% schema %}
    {
    "name": "Custom 2 image section",
    "settings": [
{
      "type": "range",
      "id": "heightcstmdesktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "vh",
      "label": "Height Desktop",
      "default": 36
    },
      {
      "type": "range",
      "id": "mobheightcstm",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "vh",
      "label": "Height Mobile",
      "default": 36
    },
                   {
   "type" :"image_picker",
      "id" : "image1",
      "label" : "Image"

},
                 {
   "type" :"image_picker",
      "id" : "image2",
      "label" : "Image"

},
      {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 36
    }
      
    ],
    
    "presets": [
    {
      "name": "Custom 2 image section"
    }
  ]
  }
{% endschema %}
{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}