<!-- tabs simple script -->
{% javascript %}
 document.addEventListener('DOMContentLoaded', () => {
    // Get the hash from the URL (e.g., #product-tab-btn2)
    const hash = window.location.hash;

    // Check if there is a hash and if it matches one of the tab buttons
    if (hash) {
        const button = document.querySelector(hash);
        if (button) {
            const tabID = button.getAttribute('data-tab');

            // Remove 'active' class from all buttons and tab contents
            document.querySelectorAll('.product-tab-link-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.product-tab-main').forEach(tab => tab.classList.remove('active'));

            // Add 'active' class to the corresponding button and tab content
            button.classList.add('active');
            document.getElementById('product-tab-' + tabID).classList.add('active');
        }
    }

    // Add event listeners to buttons for manual clicking
    document.querySelectorAll('.product-tab-link-btn').forEach(button => {
        button.addEventListener('click', () => {
            const tabID = button.getAttribute('data-tab');

            // Update the URL hash without reloading the page
            window.location.hash = button.id;

            // Remove 'active' class from all buttons and tab contents
            document.querySelectorAll('.product-tab-link-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.product-tab-main').forEach(tab => tab.classList.remove('active'));

            // Add 'active' class to the clicked button and corresponding tab content
            button.classList.add('active');
            document.getElementById('product-tab-' + tabID).classList.add('active');
        });
    });
});

{% endjavascript %}
