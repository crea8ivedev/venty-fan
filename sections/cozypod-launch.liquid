<script>
document.addEventListener("DOMContentLoaded", function () {
  const images = document.querySelectorAll(".product-image");
  const thumbnails = document.querySelectorAll(".thumbnail-list div");

  // Initially show only first image
  images.forEach((img, index) => {
    img.style.display = index === 0 ? "block" : "none";
  });

  thumbnails.forEach(thumbnail => {
    thumbnail.addEventListener("click", () => {
      const target = thumbnail.getAttribute("data-target");

      images.forEach(img => {
        img.style.display =
          img.getAttribute("data-image") === target ? "block" : "none";
      });
    });
  });
});
</script>


{% schema %}
{
  "name": "Venty Launch Section",
  "settings": [
    {
      "type": "text",
      "id": "background_text",
      "label": "Background Text",
      "default": "STAY"
    },
    {
      "type": "text",
      "id": "background_text1",
      "label": "Background Text",
      "default": "COZY"
    },
   {
      "type": "image_picker",
      "id": "main_image_1",
      "label": "Main Image 1"
    },
    {
      "type": "image_picker",
      "id": "main_image_2",
      "label": "Main Image 2"
    },
    {
      "type": "image_picker",
      "id": "main_image_3",
      "label": "Main Image 3"
    },
    {
      "type": "image_picker",
      "id": "main_image_4",
      "label": "Main Image 4"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "LAUNCHING IN JANUARY"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "With up to 1500 watts of power and whisper-quiet operation as low as 40 dB, CozyPod delivers serious heat in a compact, plug-in design. Warm enclosed spaces up to 200 square feet with three heat settings and a rechargeable remote for total control."
    }
  ],
  "blocks": [
    {
      "type": "thumbnail",
      "name": "Thumbnail Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "thumbnail_image",
          "label": "Thumbnail Image"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Venty Product Launch",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %} 
