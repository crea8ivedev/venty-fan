{% style %}
p,h1{
  margin:0;
}

/* VENTY SECTION */
.venty-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  background-color: #e9edf2;
  padding-bottom: 100px;
  padding-top: 700px;
}

/* PRODUCT AREA */
.product-showcase {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

.product-background-text {
  position: absolute;
  font-family: "Montserrat", sans-serif;
  font-size: 220px;
  font-weight: 800;
  letter-spacing: 6px;
  line-height: 200px;
  color: rgba(255, 255, 255, 0.6);
  z-index: 1;
  user-select: none;
  pointer-events: none;
  text-align: center;
  top: -60px;
  width: 100%;
  left: -18px;
}
.text-1{
  display: block;
  width: 100%;
  text-align:left;
}
.text-2{
  display: block;
  width: 100%;
  text-align:right;
}


.product-image {
  position: relative;
  z-index: 2;
  max-width: 564px;
  /* height: 702px;
  object-fit: cover; */
  top: 70px;
}

/* PRODUCT SHADOW */
.product-showcase::after {
content: "";
position: absolute;
bottom: -40px;
width: 320px;
height: 38px;
background: radial-gradient(
ellipse at center,
rgba(0, 0, 0, 0.35) 0%,
rgba(0, 0, 0, 0.18) 35%,
rgba(0, 0, 0, 0.08) 55%,
rgba(0, 0, 0, 0) 75%
);
filter: blur(8px);
z-index: 0;
}

.venty-content h1 {
    font-family: "Montserrat", sans-serif;
    font-weight: 800;
    font-size: 80px;
    line-height: 90px;
    text-transform: uppercase;
    margin: 0 0 30px;
    color: #000;  
    max-width: 566px;
    width: 100%;
}
p.venty-description {
    font-family: 'Lato', sans-serif !important;
}
.venty-description {
font-size: 20px;
  line-height: 30px;
  max-width: 528px;
  margin-bottom: 35px;
  color: #000;
}

.thumbnail-list {
display: flex;
gap: 20px;
flex-wrap: wrap;
}

.thumbnail-item {
width: 121px;
height: 121px;
background: #fff;
border-radius: 20px;
display: flex;
align-items: center;
justify-content: center;
box-shadow: 0 8px 18px rgba(0, 0, 0, 0.08);
cursor: pointer;
}

.thumbnail-image {
width: 100%;
height: 100%;
object-fit: cover;
border-radius: 25px;
}
.thumbnail-item-one,
.thumbnail-item-two,
.thumbnail-item-three,
.thumbnail-item-four {
width: 121px;
height: 121px;
background: #fff;
border-radius: 20px;
display: flex;
align-items: center;
justify-content: center;
box-shadow: 0 8px 18px rgba(0, 0, 0, 0.08);
cursor: pointer;
}

.thumbnail-image {
width: 100%;
height: 100%;
object-fit: cover;
border-radius: 25px;
}

/* TABLET */
@media (max-width: 1024px) {
.venty-section {
gap: 40px;
}

.venty-content h1 {
  font-size: 60px;
  line-height: 70px;
}
}
@media (max-width: 992px) {
  .venty-section {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .venty-content h1 {
    margin: 0 auto;       
  }
  .venty-description{
     margin: 0 auto; 
     margin-bottom: 25px;
     padding: 0 16px;
  }
  .thumbnail-list {
    justify-content: center;
  }
  .product-image{
    top: 0;
  }
  /* .cozypod-ventycrew-wrapper{
    display:none;
  } */
}
/* MOBILE */
@media (max-width: 768px) {
.page-container {
  padding: 40px 20px;
}

.venty-section {
  grid-template-columns: 1fr;
  text-align: center;
  padding-top: 100px;
  padding-bottom: 56px;

}

.product-background-text {
  font-size: 120px;
  line-height: 110px;
}

.product-image {
  top: 0;
  height: auto;
  max-width: 80%;
}

.product-showcase::after {
width: 220px;
height: 26px;
bottom: -20px;
}

.venty-content h1 {
font-size: 42px;
line-height: 48px;
}

.venty-description {
  font-size: 16px;
  line-height: 24px;
  margin-left: auto;
  margin-right: auto;
}

.thumbnail-list {
  justify-content: center;
  gap: 14px;
}

.thumbnail-item {
  width: 90px;
  height: 90px;
}
}
/* .cozypod-ventycrew-wrapper{
  display: none;
} */

@media (max-width: 768px) {
  /* .venty-section{
    display:none;
  } */
  /* .cozypod-ventycrew-wrapper{
    padding:46px 24px 80px 24px;
    display: block;
    background: #fff;
    text-align: center;
  } */
  .ozypod-ventycrew-copy{
    margin-bottom:20px;
    font-size:40px
  }

}
/* SMALL MOBILE */
@media (max-width: 480px) {
.product-background-text {
  font-size: 90px;
  line-height: 85px;
}

  .venty-content h1 {
    font-size: 34px;
    line-height: 40px;
  }
  .ozypod-ventycrew-copy{
    margin-bottom:20px;
    font-size:14px;
  }
  /* .cozypod-ventycrew-wrapper p{
    font-size:14px;
  } */
}

{%- endstyle -%}
<section class="venty-section">

<!-- PRODUCT -->
<div class="product-showcase">
<div class="product-background-text">
  <span class="text-1">{{ section.settings.background_text | newline_to_br }}</span>
  <span class="text-2">{{ section.settings.background_text1 | newline_to_br }}</span>
</div>


{% if section.settings.main_image_1 %}
  <img
    class="product-image product-image-one"
    src="{{ section.settings.main_image_1 | image_url: width: 800 }}"
    alt="{{ section.settings.main_image_1.alt | escape }}"
    data-image="1"
    loading="lazy"
    width="{{ section.settings.main_image_1.width }}"
    height="{{ section.settings.main_image_1.height }}"
  >
{% endif %}

{% if section.settings.main_image_2 %}
  <img
    class="product-image product-image-two"
    src="{{ section.settings.main_image_2 | image_url: width: 800 }}"
    alt="{{ section.settings.main_image_2.alt | escape }}"
    data-image="2"
    loading="lazy"
    width="{{ section.settings.main_image_2.width }}"
    height="{{ section.settings.main_image_2.height }}"
  >
{% endif %}

{% if section.settings.main_image_3 %}
  <img
    class="product-image product-image-three"
    src="{{ section.settings.main_image_3 | image_url: width: 800 }}"
    alt="{{ section.settings.main_image_3.alt | escape }}"
    data-image="3"
    loading="lazy"
    width="{{ section.settings.main_image_3.width }}"
    height="{{ section.settings.main_image_3.height }}"
  >
{% endif %}

{% if section.settings.main_image_4 %}
  <img
    class="product-image product-image-four"
    src="{{ section.settings.main_image_4 | image_url: width: 800 }}"
    alt="{{ section.settings.main_image_4.alt | escape }}"
    data-image="4"
    loading="lazy"
    width="{{ section.settings.main_image_4.width }}"
    height="{{ section.settings.main_image_4.height }}"
  >
{% endif %}
</div>

<!-- CONTENT -->
<div class="venty-content">
<h1>{{ section.settings.heading | newline_to_br }}</h1>

 <p class="venty-description">
    {{ section.settings.description }}
  </p>

{% if section.blocks.size > 0 %}
  <div class="thumbnail-list">
   {% for block in section.blocks %}
      {% if block.settings.thumbnail_image != blank %}
        <div
          class="thumbnail-item thumbnail-item-{{ forloop.index }}"
          data-target="{{ forloop.index }}"
          {{ block.shopify_attributes }}
        >
          <img
            class="thumbnail-image"
            src="{{ block.settings.thumbnail_image | image_url: width: 200 }}"
            alt="{{ block.settings.thumbnail_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.thumbnail_image.width }}"
            height="{{ block.settings.thumbnail_image.height }}"
            data-large="{{ block.settings.thumbnail_image | image_url: width: 800 }}"
          >
        </div>
      {% endif %}
    {% endfor %}
  </div>
{% endif %}
</div>

</section> 

