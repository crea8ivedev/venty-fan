          endcapture %}
          {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{
          settings.logo_width | times: 2 }}{% endcapture %}
          {{ settings.logo_black | image_url: width: 600 | image_tag:
          class: 'header__heading-logo motion-reduce',
          widths: widths,
          height: logo_height,
          width: settings.logo_width,
          alt: logo_alt,
          sizes: sizes,
          preload: true,
          title: logo_alt
          }}
        </div>

        <div class="header__heading-logo-wrapper">
          {% if logo_to_display %}
          {%- assign logo_alt = settings.logo_black.alt | default: shop.name | escape -%}
          {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
          {% capture sizes %}(max-width: {{ settings.logo_width | times: 2 }}px) 50vw, {{ settings.logo_width }}px{%
          endcapture %}
          {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{
          settings.logo_width | times: 2 }}{% endcapture %}
          {{ settings.logo_black | image_url: width: 600 | image_tag:
          class: 'header__heading-logo motion-reduce',
          widths: widths,
          height: logo_height,
          width: settings.logo_width,
          alt: logo_alt,
          sizes: sizes,
          preload: true,
          title: logo_alt
          }}
          {% else %}
          {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
          {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
          {% capture sizes %}(max-width: {{ settings.logo_width | times: 2 }}px) 50vw, {{ settings.logo_width }}px{%
          endcapture %}
          {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{
          settings.logo_width | times: 2 }}{% endcapture %}
          {{ settings.logo | image_url: width: 600 | image_tag:
          class: 'header__heading-logo motion-reduce',
          widths: widths,
          height: logo_height,
          width: settings.logo_width,
          alt: logo_alt,
          sizes: sizes,
          preload: true,
          title: logo_alt
          }}
          {% endif %}
        </div>

        {%- else -%}
        <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if request.page_type == 'index' -%}
    </h5>
    {%- endif -%}



    <header-drawer
      data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">

      <div id="menu-drawer"
        class="custom-drawer gradient menu-drawer motion-reduce color-{{ section.settings.menu_color_scheme }}">





        <div class="menu-drawer__inner-container">

          <div class="full-close"> </div>

          <div class="menu-drawer__navigation-container">

{% assign mega_products = blank %}

{% for block in section.blocks %}
  {% if block.type == 'mega_menu_products' %}
    {% assign mega_products = block.settings.products %}
  {% endif %}
{% endfor %}

<div class="mobile-menu-image">

{% if mega_products != blank %}

{% for product in mega_products %}

  {% assign mega_object = product.metafields.custom.product_megamenu.value %}

  {% assign mega_url = product.url %}
  {% assign mega_title = product.title %}
  {% assign mega_image = product.featured_image %}
  {% assign mega_subtitle = blank %}

  {% if mega_object != blank %}

    {% if mega_object.url != blank %}
      {% assign mega_url = mega_object.urls %}
    {% endif %}

    {% if mega_object.title != blank %}
      {% assign mega_title = mega_object.title %}
    {% endif %}

    {% if mega_object.image != blank %}
      {% assign mega_image = mega_object.image %}
    {% endif %}

    {% if mega_object.sub_title != blank %}
      {% assign mega_subtitle = mega_object.sub_title %}
    {% endif %}

  {% endif %}

  <div class="mobile-sub-menu">

    <a href="{{ mega_url }}">

      <div class="mobile-sub-image">

        {% if mega_image %}
          <img
            src="{{ mega_image | image_url: width: 300 }}"
            alt="{{ mega_title }}"
            loading="lazy">
        {% endif %}

      </div>

      {% if mega_subtitle != blank %}
        <span style="color:#35b339; font-size:12px; display:block;">
          {{ mega_subtitle }}
        </span>
      {% endif %}

      <h5>{{ mega_title }}</h5>

    </a>

  </div>

{% endfor %}

{% endif %}

</div>

{% assign mega_block = blank %}

{% for block in section.blocks %}
  {% if block.type == 'mega_menu_products' %}
    {% assign mega_block = block %}
  {% endif %}
{% endfor %}

{% if mega_block != blank %}

{% assign side_menu = linklists[mega_block.settings.side_links] %}

{% if side_menu != blank and side_menu.links.size > 0 %}

<div class="mobile-mega-side-panel">

  <ul class="mobile-mega-side-links">

    {% for parent_link in side_menu.links %}

      <li class="mobile-side-parent">

        <a href="{{ parent_link.url }}"  class="side-child-menu-title">
          {{ parent_link.title }}
        </a>

        {% if parent_link.links != blank %}
        <ul class="mobile-side-child-links">

          {% for child_link in parent_link.links %}

            <li class="mobile-side-child">

              <a href="{{ child_link.url }}" class="{% if child_link.active %}menu-active{% endif %}">
                {{ child_link.title }}
              </a>

              {% if child_link.links != blank %}
              <ul class="mobile-side-grandchild-links">

                {% for grandchild_link in child_link.links %}

                  <li class="mobile-side-grandchild">
                    <a href="{{ grandchild_link.url }}">
                      {{ grandchild_link.title }}
                    </a>
                  </li>

                {% endfor %}

              </ul>
              {% endif %}

            </li>

          {% endfor %}

        </ul>
        {% endif %}

      </li>

    {% endfor %}

  </ul>

</div>

{% endif %}
{% endif %}

            <nav class="menu-drawer__navigation">
              <ul class="menu-drawer__menu has-submenu list-menu sub-menu-mobile" role="list">
                {% for link in linklists.Mobile-menu.links %}


                <li>
                  {%- if link.links != blank -%}
                  <details id="Details-menu-drawer-menu-item-{{ forloop.index }}">
                    <summary id="HeaderDrawer-{{ link.handle }}"
                      class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.child_active %} menu-drawer__menu-item--active{% endif %}">
                      {{ link.title | escape }}
                      {% render 'icon-arrow' %}
                      {% render 'icon-caret' %}
                    </summary>
                    <div id="link-{{ link.handle | escape }}"
                      class="menu-drawer__submenu has-submenu gradient motion-reduce" tabindex="-1">
                      <div class="menu-drawer__inner-submenu">
                        <button class="menu-drawer__close-button link link--text focus-inset" aria-expanded="true">
                          {% render 'icon-arrow' %}
                          {{ link.title | escape }}
                        </button>
                        <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                          {%- for childlink in link.links -%}
                          <li>


                            {%- if childlink.links == blank -%}
                            <a id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}" href="{{ childlink.url }}"
                              class="menu-drawer__menu-item link link--text list-menu__item focus-inset{% if childlink.current %} menu-drawer__menu-item--active{% endif %}{% if childlink.type == 'collection_link' and childlink.object.featured_image %} have-image-coll{% endif %}"
                              {% if childlink.current %} aria-current="page" {% endif %}>
                              <span class="title-coll-nav">
                                {{ childlink.title | escape }}
                              </span>

                              {%- if childlink.type == 'collection_link' -%}
                              {% assign linkCollection = childlink.object %}
                              <div class="nav-collection_image">
                                {%- if linkCollection.featured_image -%}
                                <img crossorigin="anonymous" class="nav-child-link-image"
                                  src="{{ linkCollection.featured_image.src | img_url: '140x' }}"
                                  alt="{{ linkCollection.title }}">
                                <span class="nav-collection_title">
                                  {{ linkCollection.title | escape }}
                                </span>
                                {%- endif -%}
                              </div>
                              {%- endif -%}
                            </a>
                            {%- else -%}




                            <details id="Details-menu-drawer-{{ link.handle }}-{{ childlink.handle }}">
                              <summary id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                class="menu-drawer__menu-item link link--text list-menu__item focus-inset">
                                {{ childlink.title | escape }}
                                {% render 'icon-arrow' %}
                                {% render 'icon-caret' %}
                              </summary>
                              <div id="childlink-{{ childlink.handle | escape }}"
                                class="menu-drawer__submenu has-submenu gradient motion-reduce">
                                <button class="menu-drawer__close-button link link--text focus-inset"
                                  aria-expanded="true">
                                  {% render 'icon-arrow' %}
                                  {{ childlink.title | escape }}
                                </button>
                                <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                                  {%- for grandchildlink in childlink.links -%}
                                  <li>
                                    <a id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                      href="{{ grandchildlink.url }}"
                                      class="menu-drawer__menu-item link link--text list-menu__item focus-inset{% if grandchildlink.current %} menu-drawer__menu-item--active{% endif %}"
                                      {% if grandchildlink.current %} aria-current="page" {% endif %}>
                                      {{ grandchildlink.title | escape }}
                                    </a>
                                  </li>
                                  {%- endfor -%}
                                </ul>
                              </div>
                            </details>
                            {%- endif -%}
                          </li>
                          {%- endfor -%}
                        </ul>
                      </div>
                    </div>
                  </details>
                  {%- else -%}
                  <a id="HeaderDrawer-{{ link.handle }}" href="{{ link.url }}"
                    class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.current %} menu-drawer__menu-item--active{% endif %}"
                    {% if link.current %} aria-current="page" {% endif %}>
                    {{ link.title | escape }}
                  </a>
                  {%- endif -%}
                </li>
                {%- endfor -%}
              </ul>
            </nav>
            <div class="menu-drawer__utility-links">
              {%- if shop.customer_accounts_enabled -%}
              <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
                class="menu-drawer__account link focus-inset h5 medium-hide large-up-hide">
                {%- if section.settings.enable_customer_avatar -%}
                <account-icon>
                  {%- if customer and customer.has_avatar? -%}
                  {{ customer | avatar }}
                  {%- else -%}
                  {% render 'icon-account' %}
                  {%- endif -%}
                </account-icon>
                {%- else -%}
                {% render 'icon-account' %}
                {%- endif -%}
                {%- liquid
                if customer
                echo 'customer.account_fallback' | t
                else
                echo 'customer.log_in' | t
                endif
                -%}
              </a>
              {%- endif -%}
              {%- if localization.available_countries or localization.available_languages -%}
