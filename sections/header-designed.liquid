        {% assign black_logo_pages = settings.black_logo_pages | split: ',' %}


        {% assign is_account_page = false %}

        {% if template contains 'customers' %}
        {% assign is_account_page = true %}
        {% endif %}

        {% assign page_handle = false %}

        {% if current_handle contains 'pricing-disclosures-clip-fan' or current_handle contains 'pricing-disclosures' %}
        {% assign page_handle = true %}
        {% endif %}


        {% if current_handle and black_logo_pages contains current_handle or is_account_page or page_handle %}
        {% assign logo_to_display = true %}
        {% endif %}



        <!-- Black logo for mobile menu -->
        <div class="header__heading-logo-wrapper mobile-menu hide">
          {%- assign logo_alt = settings.logo_black.alt | default: shop.name | escape -%}
          {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
