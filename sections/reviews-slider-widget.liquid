<!-- Start reviews-slider-widget  -->
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mob }}px;
      padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    }
  }
{%- endstyle -%}

{%- style -%}
  img.stars-widget-slider {
    width: 170px;
}
.topcontent-widget {
    display: flex;
    flex-direction: column;
    align-items: center;
}
.smallheading-widget {
    color: rgba(128, 129, 131, 1);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-align: center;
    margin: 15px 0 0;
}
.headingbigwidget {
    color: #031133;
    font-size: 45px;
    font-weight:800;
    line-height: 55px;
    text-align: center;
    width:95%; max-width:730px;
    margin: auto;
      margin-bottom: 35px;
}
p.dnone {
    display: none;
}
  .widgethtml .jdgm-carousel--gallery-theme .jdgm-carousel-item {
    padding: 15px 10px;
}
.widgethtml .jdgm-carousel-item__inner-wrapper {
    border-radius: 13px !important;
    padding: 10px !important;
}
.widgethtml img.jdgm-carousel-item__product-image {
    border-radius: 9px !important;
}
.jdgm-star {
    font-family: 'JudgemeStar' !important;
}
.widgethtml .jdgm-carousel-item__body {
    padding: 20px 10px !important;
}
.widgethtml .jdgm-carousel-item__review-wrapper {
    align-items: flex-start !important;
    text-align: left !important;
    gap: 10px !important;
}


.widgethtml .jdgm-star {
    font-size: 14px;
}
 .widgethtml .jdgm-carousel-item__reviewer-wrapper {
    justify-content: flex-start !important;
}
.widgethtml span.jdgm-carousel-item__reviewer-name.jdgm-ellipsis {
    color: #031133 !important;
    text-align: left !important;
    font-size: 14px;
    font-weight: 500;
    line-height: 18.2px;
    letter-spacing: 0.02em;
}
.widgethtml .jdgm-carousel-item__review-rating {
    order: 1;
}
.widgethtml .jdgm-carousel-item__review-content-wrapper {
    order: 2;
}
.widgethtml .jdgm-carousel-item__reviewer-wrapper {
    order: 3;
}
.widgethtml .jdgm-carousel-item__review-title.jdgm-ellipsis{
    font-weight: 600 !important;
    color: #031133 !important;
    font-size: 18px !important;
    text-align: left !important;
}
.widgethtml .jdgm-carousel-item__review-body {
    text-align: left !important;
    color: rgba(128, 129, 131, 1);
    font-size: 13px;
    font-weight: 400;
    line-height: 18.36px;
}
.widgethtml .jdgm-carousel--gallery-theme .jdgm-carousel-item__review-body {
    height: calc(3* 18px);
}
.widgethtml .jdgm-carousel-item__inner-wrapper {
    display: flex;
    flex-direction: column;
}
.widgethtml .jdgm-carousel-item__body {
    order: 2;
}
.widgethtml .jdgm-carousel-item__image-wrapper {
    order: 1;
}
.widgethtml .jdgm-carousel__right-arrow, .widgethtml .jdgm-carousel__left-arrow {
    border: 0 !important;
    background: #f1f2f4;
    border-radius: 50%;
      transform: unset !important;
    width: 44px;
    height: 44px;
}
.widgethtml .jdgm-carousel__right-arrow::after, .widgethtml .jdgm-carousel__left-arrow::after{
      background-repeat: no-repeat;
    background-image: url(/cdn/shop/files/Line_dc248764-baf2-4806-a206-09f09d22b7b2.png?v=1723752529);
    background-size: 9px;
    background-position: center;
    width: 100%;
    height: 100%;
    content: "";
    display: inline-block;
}
.widgethtml .jdgm-carousel__right-arrow::after{
    transform: scale(-1);
}
.widgethtml .jdgm-carousel__left-arrow::after{
    transform: scale(1);
}
@media(max-width:1025px){
  .headingbigwidget {
    font-size: 40px;
    line-height: 48px;
    width: 71%;
}
}
@media(max-width:768px){
  .headingbigwidget {
    font-size: 34px;
    line-height: 40px;
    width: 100%;
            margin-bottom: 15px;
}
}
{%- endstyle -%}

<div class="section-{{ section.id }}-padding reviews-slider-widget">
  <div class="page-width">
  <div class="topcontent-widget">
    {%- if section.settings.stars -%}
{% assign alt = section.settings.stars.alt  %}     
{{
section.settings.stars
| image_url: width: 1500
| image_tag: sizes: sizes, widths: widths, class: 'stars-widget-slider', alt:alt,title: alt

}}

    {%- endif %}
    {%- if section.settings.smallheading -%}
      <div class="smallheading-widget">
        {{ section.settings.smallheading -}}
      </div>
    {%- endif %}
      {%- if section.settings.heading -%}
    <div class="headingbigwidget">
        {{ section.settings.heading -}}
    </div>
      {%- endif %}
      </div>
  </div>
    
      {%- if section.settings.widgethtml -%}
    <div class="widgethtml">
        {{ section.settings.widgethtml -}}
    </div>
      {%- endif %}
</div>
<!-- End reviews-slider-widget  -->
{% schema %}
{
  "name": "reviews slider widgets",
  "settings": [
           {
            "type": "image_picker",
            "id": "stars",
            "label": "Stars"
        },
        {
            "type": "text",
            "id": "smallheading",
            "label": "Small heading"
        },
      {
            "type": "text",
            "id": "heading",
            "label": "Heading"
        },
      {
            "type": "liquid",
            "id": "widgethtml",
            "label": "Custom Html"
        },
    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "reviews slider widgets"
    }
  ]
}
{% endschema %}
