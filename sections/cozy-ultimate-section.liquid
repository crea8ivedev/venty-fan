<!-- Start cozy-ultimate-section  -->
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mob }}px;
      padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    }
  }
{%- endstyle -%}
<style>
  .cozy-ultimate-left img {
    width: 100%;
}
.cozy-ultimate-main .page-width {
    display: flex;
    justify-content: space-between;
}
.cozy-ultimate-left {
    width: 30%;
}
.cozy-ultimate-right {
    width: 65%;
    padding-top: 70px;
}
.inner-left-single-boxe-ultimate img {
    width: 50px;
    height: 50px;
}
  .single-boxe-ultimate {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    width: 47%;
}
.main-boxes-ultimate {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    row-gap: 35px;
    margin: 60px 0px;
}
.main-boxes-ultimate h3 {
    font-size: 20px;
    font-weight: 500;
    letter-spacing: 0.01em;
    margin: 0;
    color: rgba(13, 24, 47, 1);
    text-transform: uppercase;
}
.main-boxes-ultimate p {
    margin: 0;
    color: rgba(77, 77, 77, 1);
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.01em;
    text-transform: capitalize;
      line-height: 20px
  margin-top: 8px;
}
  .title-ultimate-cozy p {
    margin: 0;
    color: #031133;
    font-size: 55px;
    font-weight: 500;
    line-height: normal;
    text-transform: capitalize;
    width: 60%;
}
  .title-ultimate-cozy p:empty {
    display:none;
}
  @media(max-width:1250px){
    .title-ultimate-cozy p {
    width: 70%;
          font-size: 48px;
}
.main-boxes-ultimate {
    margin: 40px 0px;
}

    
  }
  @media(max-width:992px){
    .title-ultimate-cozy p {
        width: 100%;
    }
    .main-boxes-ultimate {
        row-gap: 20px;
    }

  }
  @media(max-width:769px){
        .cozy-ultimate-main .page-width {
    flex-direction: column;
}
    .cozy-ultimate-left {
    width: 30%;
    margin: auto;
}
    .cozy-ultimate-right {
    width: 100%;
    padding-top: 10px;
}
    .single-boxe-ultimate {
    width: 100%;
}
  }
  @media(max-width:500px){
        .title-ultimate-cozy p {
        font-size: 40px;
    }
  }
  @media(max-width:390px){
    
  }
  

.Specs-command {
    display: none;
   
}
  
@media(max-width:500px){

.Specs-command {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    column-gap: 10px;     padding: 15px 0; 
}
.Specs-command-part-left .Specs-command-items,  
.Specs-command-part-center .Specs-command-items,
.Specs-command-part-right .Specs-command-items{
    text-align: center; border-radius: 8px;
background: #F1F2F4;     padding: 6px 2px; margin: 10px 0;  min-height:135px;
}  
 .Specs-command-part-left h6,  
.Specs-command-part-center h6,
.Specs-command-part-right h6{
  margin:0;
}  
 .Specs-command-part-left p,  
.Specs-command-part-center p,
.Specs-command-part-right p{
  margin:0; font-size:8px;
}   

.Specs-command-items h6 {
    font-size: 9.5px;
    line-height: 1.4;
}

  
.Specs-command-part-center .Specs-command-items:nth-child(2) {
   
    background-color: inherit;
    min-height: 270px;  margin:0;
}

.Specs-command-items img {
	max-width: 100%;
	width: 60px;
}
      
.Specs-command-part-center .Specs-command-items:nth-child(2) img {
    max-width: 100%;
    width: 106.66px;
    height: 260px;
    flex-shrink: 0;
}

  .cozy-ultimate-left {
        width: 66%;
  }

  }
    
  
</style>

<div class="section-{{ section.id }}-padding cozy-ultimate-main">
  <div class="page-width">

      <div class="title-ultimate-cozy m--show" style="        text-align: center;">{{ section.settings.heading }}</div>

    
    <div class="cozy-ultimate-left">
       {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
{%- capture sizes -%}
(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 1 }}px,
(min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
{%- endcapture -%}
{% assign alt = section.settings.img.alt %}            
{{
section.settings.img
| image_url: width: 1500
| image_tag: sizes: sizes, widths: widths ,alt:alt
}}
    </div>
    <div class="cozy-ultimate-right">
      <div class="title-ultimate-cozy d--show">{{ section.settings.heading }}</div>

      <div class="main-boxes-ultimate">
           {%- for block in section.blocks -%}
        {% if block.type == 'boxes' %}
        <div class="single-boxe-ultimate">
          <div class="inner-left-single-boxe-ultimate">
{% assign alt = block.settings.icon.alt %}            
{{
block.settings.icon
| image_url: width: 1500
| image_tag: sizes: sizes, widths: widths ,alt:alt
}}

          </div>
          <div class="inner-right-single-boxe-ultimate">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.para }}</p>
          </div>
        </div>
        {% endif %}
          {% endfor %}
      </div>

            <a class="btn-benefit-wrapper" href="{{ section.settings.button_link_1 }}">
        {{ section.settings.button_text_1 }}
        <span>
          <img src="https://cdn.shopify.com/s/files/1/0613/3297/9961/files/Right_25.png">
        </span>
      </a>
   </div>

     
  <div class="title-ultimate-cozy m--show" style="     text-align: center;">{{ section.settings.heading1 }} </div>

  
  <div class="Specs-command">

   
      
      <div class="Specs-command-part-left">
         {%- for block in section.blocks -%}
       {% if block.type == 'left' %}
         
        <div class="Specs-command-items">

{% assign alt = block.settings.image1.alt %}            
{{
block.settings.image1
| image_url: width: 1500
| image_tag: sizes: sizes, widths: widths ,alt:alt
}}
          <h6>{{ block.settings.title1 }}</h6>
          {{ block.settings.content1 }}
         </div>
        
       {% endif %}
  {% endfor %}      
      </div>
  
       <div class="Specs-command-part-center">
         {%- for block in section.blocks -%}
       {% if block.type == 'center' %}
        <div class="Specs-command-items">
{% assign alt = block.settings.image2.alt %}            
{{
block.settings.image2
| image_url: width: 1500
| image_tag: sizes: sizes, widths: widths ,alt:alt
}}
           <h6>{{ block.settings.title2 }}</h6>
          {{ block.settings.content2 }}
         </div>

          {% endif %}
  {% endfor %}
        </div>


       <div class="Specs-command-part-right">

         {%- for block in section.blocks -%}
       {% if block.type == 'right' %}
        <div class="Specs-command-items">
          {% assign alt = block.settings.image3.alt %}            
{{
block.settings.image3
| image_url: width: 1500
| image_tag: sizes: sizes, widths: widths ,alt:alt
}}
          <h6>{{ block.settings.title3 }}</h6>
          {{ block.settings.content3 }}
         </div>
 {% endif %}
  {% endfor %}  
      </div>
      
    </div>
    
  </div>
</div>

<!-- End cozy-ultimate-section  -->
{% schema %}
{
  "name": "Cozy Ultimate Section",
  "settings": [
      {
      "type": "image_picker",
      "id": "img",
      "label": "Main image"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Main Heading"
    }, 
      {
      "type": "text",
      "id": "button_text_1",
      "label": "Button Text 1"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button Url 1"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "richtext",
      "id":"heading1",
      "label":"Heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 36
    }
  ],
        "blocks": [
    {
      "type": "boxes",
      "name": "Benefits",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "icon"
        },
       {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
       {
          "type": "text",
          "id": "para",
          "label": "Description"
        }
      ]
    },
          {
            "type": "left",
            "name":"Left Content",
            "limit": 4,
            "settings": [
              {
          "type": "image_picker",
          "id": "image1",
          "label": "Icon"
        },
       {
          "type": "text",
          "id": "title1",
          "label": "Title"
        },
       {
          "type": "richtext",
          "id": "content1",
          "label": "Content"
        }
            ]
          },
          {
            "type": "center",
            "name":"Center Content",
            "limit": 3,
            "settings": [
              {
          "type": "image_picker",
          "id": "image2",
          "label": "Icon"
        },
       {
          "type": "text",
          "id": "title2",
          "label": "Title"
        },
       {
          "type": "richtext",
          "id": "content2",
          "label": "Content"
        }
            ]
          },
          {
            "type": "right",
            "name":"Right Content",
            "limit": 4,
            "settings": [
              {
          "type": "image_picker",
          "id": "image3",
          "label": "Icon"
        },
       {
          "type": "text",
          "id": "title3",
          "label": "Title"
        },
       {
          "type": "richtext",
          "id": "content3",
          "label": "Content"
        }
            ]
          }
        ],
  "presets": [
    {
      "name": "Cozy Ultimate Section",
          "blocks": [
        {
          "type": "boxes"
        }
      ]
    }
  ]
}
{% endschema %}
