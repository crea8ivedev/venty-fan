<div class="campaign-addons-main animate--zoom-in">
  <div class="campaign-addons page-width">
    <div class="addons-header">
    <h2>{{ section.settings.heading }}</h2>

    <div class="addons-divider">
      <span class="line"></span>

      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: 80 }}" alt="logo" class="divider-logo">
      {% endif %}

      <span class="line"></span>
    </div>
  </div>

    <div class="addons-grid">
      {% for block in section.blocks %}
        <div class="addon-card">
          
          {% if block.settings.image != blank %}
            <div class="addon-image">
              {{ block.settings.image | image_url: width: 600 | image_tag }}
            </div>
          {% endif %}

          <div class="addon-info">
            <h3>{{ block.settings.title }}</h3>
            <p class="addon-price">{{ block.settings.price }}</p>
          </div>

        </div>
      {% endfor %}
    </div>
  </div>
</div>
<style>
  .campaign-addons-main{
      padding-right: 35px;
      padding-left: 35px;
  }
    .campaign-addons {
      text-align: center;
      padding: 60px 0px;
      max-width: 1254px;
    }

  .addons-header h2 {
      font-size: 63px;
      margin-bottom: 30px;
      letter-spacing: 2px;
      color: #434343;
      font-weight: 700;
      text-transform: uppercase;
  }
  .addons-grid{
      display: grid;
      grid-template-columns: repeat(3,1fr);
      gap: 24px;
  }

  .addon-card{
      border-radius:20px;
  }

  .addon-image img {
      width: 100%;
      border-radius: 12px;
      height: 100%;
      max-height: 852px;
  }

.addon-info h3 {
    margin-top: 30px!important;
    font-size: 35px;
    text-transform: uppercase;
    color: #1D1D1D;
    max-width: 322px;
    margin: 0 auto;
    min-height: 88px;
}

.addon-price{
  font-weight:600;
  margin-top:5px;
  font-size:35px;
  color:#1D1D1D;
}
.addons-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-top: 10px;
    padding-bottom: 40px;
}

.addons-divider .line{
  height:5px;
  width:538px;
  background:#434343;
}

.divider-logo {
    width: 112px;
    height: 106px;
}
</style>
{% schema %}
{
  "name": "Campaign Add-ons",
  "settings": [
  {
    "type": "inline_richtext",
    "id": "heading",
    "label": "Heading",
    "default": "Campaign Add-ons"
  },
  {
    "type": "image_picker",
    "id": "logo",
    "label": "Divider Logo"
  }
],
  "blocks": [
    {
      "type": "addon",
      "name": "Addon Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Addon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Addon Title"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Campaign Add-ons"
    }
  ]
}
{% endschema %}