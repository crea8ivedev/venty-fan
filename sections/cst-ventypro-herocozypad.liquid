    border-radius: 50px;
    color: #ffffff;
    text-decoration: none;
    margin-top: 28px;
    font-size: 14px;
    line-height: 24px;
    font-weight: 700;
}
.tkform-active{
  {% comment %} display: block; {% endcomment %}
  opacity: 1;
  visibility: visible;
}

