{% schema %}
{
"name": "Cozypad Ventypro",
"settings": [
  { "type": "image_picker", "id": "hero_logo", "label": "Hero logo (top center)" },
  { "type": "image_picker", "id": "bg_image", "label": "Background image" },
  { "type": "image_picker", "id": "bg_image_mobile", "label": "Background image mobile" },
  { "type": "image_picker", "id": "center_image", "label": "Center Image Mobile" },
  { "type": "text", "id": "word_plug", "label": "Heading – PLUG (bold)", "default": "PLUG" },
  { "type": "text", "id": "word_cozy", "label": "Heading – COZY. (bold)", "default": "COZY." },
  { "type": "textarea", "id": "subheading", "label": "Subheading" },
  { "type": "textarea", "id": "joinus", "label": "Join us text" },
  { "type": "text", "id": "email_placeholder", "label": "Email placeholder", "default": "Email address" },
  { "type": "text", "id": "button_label", "label": "Button text", "default": "Sign up to See Launch Day Pricing" },
  { "type": "checkbox", "id": "show_signup_form", "label": "Show sign up form", "default": true },
  { "type": "text", "id": "alt_button_text", "label": "Alternative button text", "default": "Learn More" },
  { "type": "url", "id": "alt_button_link", "label": "Alternative button link" }

],
"presets": [
  { "name": "Cozypad Ventypro" }
]
}
{% endschema %}
