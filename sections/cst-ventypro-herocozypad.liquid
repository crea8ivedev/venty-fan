<style>
.cst-popup-form {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    background:rgba(0, 0, 0, 0.3);
    z-index: 3;
    {% comment %} display: none; {% endcomment %}
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;    
}
.cst-popup-form-inner {
    max-width: 1000px;
    margin: 0 auto;
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 10px;
    transform: translate(-50%, -50%);
    {% comment %} transform: translateX(-50%); {% endcomment %}
    width: 100%;
    background-image: url(https://cdn.shopify.com/s/files/1/0613/3297/9961/files/popup-image.png?v=1772781711);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 9;
    padding: 40px;
        display: flex;
    flex-direction: column;
    justify-content: center;
}
.cst-popup-form-inner h2 {
    font-size: 48px;
    line-height: 48px;
    color: #fff;
    font-weight: 700;
    margin: 0px;
}
.cst-popup-form-inner-price.original-price span:last-child {
    font-size: 40px;
    line-height: 40px;
    font-weight: 500;
}
.cst-popup-form-inner h3 {
    font-size: 32px;
    line-height: 32px;
    color: #fff;
    margin: 0px;
}
.cst-popup-form-inner-price span {
    font-size: 20px;
    display: block;
}
.cst-popup-form-inner-price.regular-price,.cst-popup-form-inner-price.original-price {margin-top: 28px;}

.cst-popup-form-inner-price.original-price span:last-child {
    font-size: 40px;
    line-height: 40px;
    font-weight: 500;
}

.cst-popup-form-inner-price.regular-price span:first-child {
    font-weight: 600;
}

.cst-popup-form-inner-price.regular-price span:last-child {
    font-weight: 700;
    font-size: 40px;
    line-height: 40px;
}
.cst-popup-form-close {
    display: flex !important;
    width: 30px;
    height: 30px;
    background: #fff;
    position: absolute;
    right: 19px;
    top: 14px;
    border-radius: 50px;
    z-index: 3;
    color: #000;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    cursor: pointer;
}
a.cst-popup-form-link {
    display: inline-block;
