<script src="https://unpkg.com/flickity@2/dist/flickity.pkgd.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/flickity@2/dist/flickity.min.css">

{%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
      background-color: {{ section.settings.background }};
    }

  {% if section.settings.customheightenable %}
       .section-{{ section.id }}-padding {
      padding-top: 0 !important;
      padding-bottom: 0 !important;
      height:{{section.settings.heightcstm}}vh;
    }
    .logo_slider_advanced .flickity-section__carousel,
      .logo_slider_advanced .flickity-viewport {
      height: 100% !important;
  }

    @media only screen and (max-width:500px) {
   .section-{{ section.id }}-padding {
       max-height: 57px;
    }
    }

    
  {% endif %}


    #carousel-cell-{{ section.id }} {
    width: {{ section.settings.cell_width }}; /* Ensure this line is correct */
  }

  .logo_slider_advanced .page-width {
      height: 100%;
  }


            {%- for block in section.blocks -%}
              {% if block.type == 'imagesizing' %}
      #block-{{ section.id }}-{{ block.id }} {
        width: {{ block.settings.imagesize }}%;
      }
                {% endif %}
        {%- endfor -%}

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    @media screen and (max-width: 768px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top_mob }}px;
        padding-bottom: {{ section.settings.padding_bottom_mob }}px;
      }
            {%- for block in section.blocks -%}
              {% if block.type == 'imagesizing' %}
      #block-{{ section.id }}-{{ block.id }} {
        width: {{ block.settings.imagesizemobile }}%;
      }
                 {% endif %}
        {%- endfor -%}

        #carousel-cell-{{ section.id }} {
    width: {{ section.settings.cell_width_mobile }}; /* Ensure this line is correct */
  }


    }
{%- endstyle -%}

<div class="logo_slider_advanced section-{{ section.id }}-padding">
  <div class="page-width">
    {% assign cell_align = section.settings.cell_align %}
    {% assign wrap_around = section.settings.wrap_around %}
    {% assign draggable = section.settings.draggable %}
    {% assign autoplay_speed = section.settings.autoplay_speed %}
    {% assign img_width = section.settings.img_width | append: 'x' %}

    <div
      class="flickity-section__carousel carousel-{{section.id }} text-center"
      data-flickity='
          {
          "cellAlign": "{{ cell_align }}",
          "pageDots": false,
          "freeScroll": true,
          "contain": true,
        "draggable":{{ draggable }},
          "wrapAround": {{ wrap_around }},
          "autoPlay": {{ autoplay_speed }}
          }
      '
    >
      {%- for block in section.blocks -%}
        {% if block.type == 'imagesizing' %}
          <div
            class="carousel__cell"
            style="margin-right:{{ section.settings.mr }}px"
            id="carousel-cell-{{ section.id }}"
          >{% assign alt = block.settings.img1.alt %}
            {%- if block.settings.img1 -%}
            
              <img
                src="{{ block.settings.img1 | img_url: 'master' }}"
                class="cstm-witdh-only"
                id="block-{{ section.id }}-{{ block.id }}"
                alt="{{ alt }}"
                title="{{ alt }}"
              >
             
            {%- endif %}
          </div>
        {% endif %}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Logo Slider Advanced",
  "settings": [
    {
      "type": "checkbox",
      "id": "customheightenable",
      "default": false,
      "label": "Enable For Custom Height Padding Wont Work"
    },
    {
      "type": "range",
      "id": "heightcstm",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "vh",
      "label": "Height",
      "default": 36
    },
    {
      "type": "select",
      "id": "cell_width",
      "label": "Choose number of slides to show on start (desktop)",
      "options": [
        {
          "value": "80%",
          "label": "One"
        },
        {
          "value": "40%",
          "label": "Two"
        },
        {
          "value": "30%",
          "label": "Three"
        },
        {
          "value": "25%",
          "label": "Four"
        },
        {
          "value": "20%",
          "label": "Five"
        },
        {
          "value": "16.6666667%",
          "label": "Six"
        },
        {
          "value": "12.5%",
          "label": "Eight"
        }
      ],
      "default": "25%"
    },
    {
      "type": "select",
      "id": "cell_width_mobile",
      "label": "Choose number of slides to show on start (mobile)",
      "options": [
        {
          "value": "80%",
          "label": "One"
        },
        {
          "value": "47%",
          "label": "Two"
        },
        {
          "value": "30%",
          "label": "Three"
        },
        {
          "value": "25%",
          "label": "Four"
        },
        {
          "value": "20%",
          "label": "Five"
        },
        {
          "value": "16.6666667%",
          "label": "Six"
        },
        {
          "value": "12.5%",
          "label": "Eight"
        }
      ],
      "default": "25%"
    },
    {
      "type": "radio",
      "id": "wrap_around",
      "label": "Enable Wrap Around (endless scrolling)",
      "options": [
        {
          "value": "true",
          "label": "True"
        },
        {
          "value": "false",
          "label": "False"
        }
      ],
      "default": "true"
    },
    {
      "type": "select",
      "id": "cell_align",
      "label": "Slide Alignment",
      "options": [
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "left",
          "label": "Left"
        }
      ],
      "default": "center"
    },
    {
      "type": "radio",
      "id": "draggable",
      "label": "Draggable",
      "options": [
        {
          "value": "true",
          "label": "True"
        },
        {
          "value": "false",
          "label": "False"
        }
      ],
      "default": "true"
    },

    {
      "type": "select",
      "id": "autoplay_speed",
      "label": "Autoplay Speed (ms)",
      "options": [
        {
          "value": "3000",
          "label": "3 Seconds Delay"
        },
        {
          "value": "5000",
          "label": "5 Seconds Delay"
        },
        {
          "value": "10000",
          "label": "10 Seconds Delay"
        },
        {
          "value": "false",
          "label": "Auto Play Off"
        }
      ],
      "default": "false"
    },

    {
      "type": "range",
      "id": "mr",
      "min": 0,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Cell Margin Right",
      "default": 16,
      "info": "Save page to see changes."
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "imagesizing",
      "name": "Logo Slider",
      "settings": [
        {
          "type": "image_picker",
          "id": "img1",
          "label": "Brand image"
        },
        {
          "type": "range",
          "id": "imagesize",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "image size",
          "default": 36
        },
        {
          "type": "range",
          "id": "imagesizemobile",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "image size for mobile",
          "default": 36
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo Slider Advanced"
    }
  ]
}
{% endschema %}
