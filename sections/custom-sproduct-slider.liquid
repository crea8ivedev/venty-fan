      "label": "Sub Heading"
    },
             {
   "type" :"image_picker",
      "id" : "image",
      "label" : "Image"

}
      
    ],
    "blocks":[
			 {

               "type": "video",
                "name": "video",
                "settings": [
                {
        "type": "video",
        "id": "video",
        "label": "Video"
      }

                ]
             }
    ],
    "presets": [
    {
      "name": "Custom Sproduct Slider"
    }
  ]
  }
{% endschema %}
{% stylesheet %}
{% endstylesheet %}

{% javascript %}

  const slider = document.querySelector('.video-slider');
const prevBtn = document.querySelector('.prev-slide');
const nextBtn = document.querySelector('.next-slide');

let currentSlide = 0;

prevBtn.addEventListener('click', () => {
    if (currentSlide > 0) {
        currentSlide--;
        updateSlider();
    }
});

nextBtn.addEventListener('click', () => {
    if (currentSlide < slider.children.length - 3) { // Show only up to the last half-visible slide
        currentSlide++;
        updateSlider();
    }
});

function updateSlider() {
    slider.style.transform = `translateX(-${currentSlide * (100 / 3.5)}%)`;
}

{% endjavascript %}