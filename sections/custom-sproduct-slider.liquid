<div class="video-slider-container">
    <div class="video-slider">
        {% for block in section.blocks %}
            <div class="video-slide">
                {% if block.settings.video != blank %}
                   {{ block.settings.video | media_tag }}
                {% endif %}
            </div>
        {% endfor %}
    </div>

    <div class="slider-navigation">
        <button class="prev-slide">◀</button>
        <button class="next-slide">▶</button>
    </div>
</div>



<style>
  .video-slider-container {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding-bottom: 20px; /* Space for the arrows */
}

.video-slider {
    display: flex;
    transition: transform 0.3s ease-in-out;
}

.video-slide {
    min-width: calc(100% / 3.5); /* Show 3.5 slides, making the 4th half-visible */
    box-sizing: border-box;
    padding: 0 10px;
}

video {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 10px;
}

.slider-navigation {
    text-align: center;
    position: absolute;
    bottom: 0;
    width: 100%;
}

.prev-slide, .next-slide {
    background-color: #333;
    color: white;
    border: none;
    padding: 10px;
    cursor: pointer;
    margin: 0 5px;
    border-radius: 50%;
}

.prev-slide:hover, .next-slide:hover {
    background-color: #555;
}

</style>


















       
