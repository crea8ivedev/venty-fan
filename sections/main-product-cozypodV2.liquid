    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const scope = document.querySelector('#MainProduct-{{ section.id }}');
        if (!scope) return;

        const productForm = scope.querySelector('form[id^="product-form-"]');
        if (!productForm) return;

        let busy = false;
        let lastSubmitToken = null;

        const getBundleQty = () => {
          const pseudo = scope.querySelector('.pseudo-variants');
          if (!pseudo) return 1;
          if (pseudo.classList.contains('is-four')) return 4;
          if (pseudo.classList.contains('is-double')) return 2;
          return 1;
        };

        const getSelectedAddonVariantIds = () => {
          const ids = [];
          scope.querySelectorAll('.addon-item').forEach((item) => {
            const toggle = item.querySelector('.addon-toggle-ui');
            if (!toggle?.classList.contains('is-active')) return;

            const vid = item.dataset.variantId;
            if (vid) ids.push(String(vid));
          });
          return ids;
        };

        const cartHasAny = (cart, variantIds) => {
          const set = new Set(variantIds.map(String));
          return (cart.items || []).some((it) => set.has(String(it.variant_id)));
        };

        async function waitForMainAdd(previousItemCount) {
          for (let i = 0; i < 16; i++) {
            // ~4s total
            await new Promise((r) => setTimeout(r, 250));
            const cart = await fetch('/cart.js', { credentials: 'same-origin' }).then((r) => r.json());
            if ((cart.item_count || 0) > previousItemCount) return cart;
          }
          return fetch('/cart.js', { credentials: 'same-origin' }).then((r) => r.json());
        }

        async function addSelectedAddons() {
          const addonIds = getSelectedAddonVariantIds();
          if (!addonIds.length) return;

          const bundleQty = getBundleQty();

          // Prevent duplicates if already in cart
          const cartNow = await fetch('/cart.js', { credentials: 'same-origin' }).then((r) => r.json());
          if (cartHasAny(cartNow, addonIds)) return;

          const items = addonIds.map((id) => ({
            id,
            quantity: bundleQty,
            properties: { _addon: 'true', _addon_source: 'pdp' },
          }));

          await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ items }),
          });

          document.dispatchEvent(new CustomEvent('cart:refresh'));
          document.dispatchEvent(new CustomEvent('cart:update'));
        }

        productForm.addEventListener('submit', async () => {
          // One-shot token per submit to reduce double triggers
          const token = Date.now() + ':' + Math.random().toString(16).slice(2);
          lastSubmitToken = token;

          if (busy) return;
          busy = true;

          try {
            const before = await fetch('/cart.js', { credentials: 'same-origin' }).then((r) => r.json());
            const beforeCount = before.item_count || 0;

            await waitForMainAdd(beforeCount);

            // If another submit happened while we waited, skip
            if (lastSubmitToken !== token) return;

            await addSelectedAddons();
          } catch (err) {
            console.error('[Addons] Error:', err);
          } finally {
            busy = false;
          }
        });
      });
    </script>
