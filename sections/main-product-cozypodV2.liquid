{% comment %}
  <script>
  document.addEventListener('DOMContentLoaded', () => {
    const pseudo = document.querySelector('.pseudo-variants');
    if (!pseudo) return;

    const productInfo = document.querySelector('product-info');
    if (!productInfo) return;

    /* ---------- Примусове оновлення кількості ---------- */
    const setProductQuantity = (qty) => {
      const qtyInput = productInfo.querySelector('.quantity__input');
      if (!qtyInput) return;
      qtyInput.value = qty;
      qtyInput.dispatchEvent(new Event('change', { bubbles: true }));
      console.log(`[Pseudo] Quantity set → ${qty}`);
    };

    /* ---------- BUY 1 / BUY 2 ---------- */
    const singleCheckbox = pseudo.querySelector('input[name="pseudo_variant_checkbox--single"]');
    const doubleCheckbox = pseudo.querySelector('input[name="pseudo_variant_checkbox--double"]');

    const toggleBundle = (sel, skipQty = false) => {
      if (sel === 'single') {
        singleCheckbox.checked = true;
        doubleCheckbox.checked = false;
        pseudo.classList.add('is-single');
        pseudo.classList.remove('is-double');
        if (!skipQty) setProductQuantity(1);
      } else {
        doubleCheckbox.checked = true;
        singleCheckbox.checked = false;
        pseudo.classList.add('is-double');
        pseudo.classList.remove('is-single');
        if (!skipQty) setProductQuantity(2);
      }
      console.log(`[Pseudo] Mode changed → ${sel}`);
    };

    singleCheckbox?.addEventListener('change', () => toggleBundle('single'));
    doubleCheckbox?.addEventListener('change', () => toggleBundle('double'));

    /* ---------- ⚙️ Примусовий reset після повернення з checkout ---------- */
    // Спочатку знімаємо все
    singleCheckbox.checked = false;
    doubleCheckbox.checked = false;
    pseudo.classList.remove('is-double', 'is-single');

    // Через коротку паузу виставляємо single + кількість 1
    setTimeout(() => {
      toggleBundle('single');
    }, 50);

    /* ---------- Shopify перерендерює кількість при зміні варіанта ---------- */
    let updateTimeout;
    const observer = new MutationObserver(() => {
      clearTimeout(updateTimeout);
      updateTimeout = setTimeout(() => {
        const isDouble = pseudo.classList.contains('is-double');
        setProductQuantity(isDouble ? 2 : 1);
      }, 100);
    });
    observer.observe(productInfo, { childList: true, subtree: true });
  });
  </script>
