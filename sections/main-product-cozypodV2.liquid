<script>
  document.addEventListener('click', function (e) {
    const link = e.target.closest('.addon-link');
    if (link) {
      e.preventDefault();
      const sel = link.getAttribute('data-popup') || '.addon-popup-overlay';
      const popup = document.querySelector(sel);
      if (popup) popup.style.display = 'flex';
      return;
    }

    if (e.target.classList.contains('addon-popup-overlay') || e.target.classList.contains('addon-popup-close')) {
      const popup = e.target.closest('.addon-popup-overlay') || document.querySelector('.addon-popup-overlay');
      if (popup) popup.style.display = 'none';
    }
  });
</script>

