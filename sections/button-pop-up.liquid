{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  
  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mob }}px;
      padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    }
  }

.three-btn-section .page-width {
    gap: 50px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
}
button.open-popup {
    padding: 28px 33px;     background-color: initial;     border-radius: 13px;     border: 1px solid #DCDDDE;     cursor: pointer;
}
button.open-popup:hover{
  border: 1px solid #000;
}

.three-btn-section .page-width a {
    color: rgba(77, 77, 77, 1);
    font-size: 18px;
    font-weight: 500;
    line-height: 25.08px;
    text-align: center;
    text-decoration: none;
    text-transform: capitalize;
    border:none;
    border-radius: 6px;
    padding:0px !important;
}

  @media(max-width:768px){
    .three-btn-section .page-width {
    gap: 13px;
    flex-wrap: wrap;
}
    .three-btn-section .page-width a {
    width: 100%;
}
}









  
  /* Basic popup styling */
.popup {
    display: none; /* Hidden by default */
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5); /* Semi-transparent background */
    z-index: 1000;
    justify-content: center;
    align-items: center;
}

.popup-content {
    background-color: #fff;
    padding: 50px;
    border-radius:44px;
    width: 80%;
    max-width: 1300px;
    position: relative;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.3);
    max-height: 80vh;    
  
}

.t-contant {
    overflow-y: scroll;
    width: 100%;
    max-height: 60vh;
    display: block; scrollbar-width: thin;
}
span.close-popup svg {
    height: 25px;
    width: 25px;
}
.popup-content h6 {
    font-weight: 500;
    color:#031133;
    font-size: 38px;
    text-align: left;
    margin: 10px 0;
}  

.close-popup {
    position: absolute;
    top: 25px;
    right: 25px;
    font-size: 20px;
    cursor: pointer;
}


@media(max-width:1199){
.three-btn-section .page-width {
    gap: 30px;
    display: grid;
    grid-template-columns: 1fr 1fr;
}
   
 }
 @media(max-width:667px){
.three-btn-section .page-width {
    display: grid;
    grid-template-columns: 1fr;
}
.popup-content a {
    border: none !important;
    font-size: 14px !important;
    padding: 0 !important;
    max-width: 100px !important;
    overflow-wrap: break-word;
}

.popup-content {
  
    padding: 20px;
    border-radius: 25px;
    width: 95%;
   
}
.popup-content h6 {
   font-size: 26px;
}


   
 }

  
{%- endstyle -%}
 

        <div class="section-{{ section.id }}-padding three-btn-section">
  <div class="page-width">
        {% if section.settings.button_text_1 != blank %}
 <a href=" {{ section.settings.button_link_1 }}"> <h6> {{ section.settings.button_text_1 }}  </h6>
<p> {{ section.settings.button_content_1 }} </p>
 </a>
{% endif %}

{% for block in section.blocks %}
    <!-- Trigger Buttons -->
<button class="open-popup" data-popup="popup{{ forloop.index }}"><h6> {{ block.settings.button_text_1 }}  </h6><p> {{ block.settings.button_content_1 }} </p></button>

{% endfor %}


    </div>
</div>

{% for block in section.blocks %}    
<!-- Pop-ups -->
<div class="popup" id="popup{{ forloop.index }}">
    <div class="popup-content">
        <span class="close-popup"><svg xmlns="http://www.w3.org/2000/svg" width="39" height="39" viewBox="0 0 39 39" fill="none">
<path d="M24.374 24.375L14.625 14.625M14.626 24.375L24.375 14.625" stroke="#BABBBD" stroke-width="2.4375" stroke-linecap="round" stroke-linejoin="round"/>
<path d="M35.75 19.5C35.75 10.5254 28.4745 3.25 19.5 3.25C10.5254 3.25 3.25 10.5254 3.25 19.5C3.25 28.4745 10.5254 35.75 19.5 35.75C28.4745 35.75 35.75 28.4745 35.75 19.5Z" stroke="#BABBBD" stroke-width="2.4375"/>
</svg></span>
      <h6> {{ block.settings.button_text_1 }}  </h6>
      {% if block.settings.text != blank %}
      {{ block.settings.text }}
      {% else block.settings.page != blank%}
       {%- if block.settings.page.content != blank -%} <div class="t-contant"> {{ block.settings.page.content }}</div>{% endif %}
        
      {% endif %}
    </div>
</div>
 {% endfor %}
       
{% schema %}
    {
    "name": "Button Pop Up",
    "settings": [

    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 36
    }
      
    ],
      "blocks": [
        {
          "type": "tab",
          "name":"Tab",
          "settings": [
            {
                  "type": "text",
                    "id": "button_text_1",
                  "label":"Button Text 1"
                }, 
            {
                  "type": "text",
                    "id": "button_content_1",
                  "label":"Button content 1"
             },
            {
              "type": "header",
              "content": "Pop up Content"
            },
            {
                 "type": "page",
                "id": "page",
                "label": "t:sections.page.settings.page.label"
            },
            {
              "type": "richtext",
              "id":"text",
              "label": "Content"
            }
          ]
        }
      ],
    "presets": [
    {
      "name": "Button Pop Up"
    }
  ]
  }
{% endschema %}
 

{% javascript %}

  document.addEventListener('DOMContentLoaded', () => {
    // Function to open a popup
    const openPopup = (popupId) => {
        document.getElementById(popupId).style.display = 'flex';
    };

    // Function to close a popup
    const closePopup = () => {
        document.querySelectorAll('.popup').forEach(popup => {
            popup.style.display = 'none';
        });
    };

    // Attach click event to all buttons with class 'open-popup'
    document.querySelectorAll('.open-popup').forEach(button => {
        button.addEventListener('click', () => {
            const popupId = button.getAttribute('data-popup');
            openPopup(popupId);
        });
    });

    // Attach click event to all close buttons inside popups
    document.querySelectorAll('.close-popup').forEach(button => {
        button.addEventListener('click', closePopup);
    });

    // Close popup when clicking outside of the content area
    document.querySelectorAll('.popup').forEach(popup => {
        popup.addEventListener('click', (event) => {
            if (event.target === popup) {
                closePopup();
            }
        });
    });
});


  
{% endjavascript %}