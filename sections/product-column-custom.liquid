<!-- Start Product-Column-Custom  -->
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mob }}px;
      padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    }
  }
{%- endstyle -%}


<div id="{{ section.settings.section_id }}" class="product_custom-column section-{{ section.id }}-padding">
  <div class="page-width">

      <h3>{{ section.settings.title }}</h3>
    
  </div>

  
  <div class="page-width">
    


          {%- for block in section.blocks -%}
        {% if block.type == 'product-custom' %}
          <div class="single-product-column-custom">
            <a href="{{ block.settings.linkproduct }}{% if block.settings.linkproductvariantid != blank %}?variant={{ block.settings.linkproductvariantid }}{% endif %}" class="{% if request.host contains 'ventyfan.co.uk'  and block.settings.title contains 'VENTY CLIP FAN' %}
no-URL
{% endif %}

{% if   shop.secure_url contains 'en-au'  and block.settings.title contains 'VENTY CLIP FAN' %} no-URL {% endif %}
" >

{%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
{%- capture sizes -%}
(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 3 }}px,
(min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
{%- endcapture -%}
            
           
{% assign alt = block.settings.img1.alt  %}
{{
block.settings.img1
| image_url: width: 1500
| image_tag: sizes: sizes, widths: widths, alt: alt, title: alt
}}

{% if block.settings.text4 != blank %} 
<span style="color: #35b339 !important; line-height:1; margin:0px; font-size:12px; display: block;
  clear: both;"> {{ block.settings.text4 }}</span>     
 {% endif %}      

              {% if request.host contains 'ventyfan.co.uk'  and block.settings.title contains 'VENTY CLIP FAN' %}
<span style="color: #35b339 !important; line-height:1; margin-bottom:0px; font-size:12px; "> coming soom </span>
{% endif %}

{% if   shop.secure_url contains 'en-au'  and block.settings.title contains 'VENTY CLIP FAN' %}
<span style="color: #35b339 !important; line-height:1; margin-bottom:0px; font-size:12px; "> coming soom </span>
{% endif %}  

              
            <h2>{{ block.settings.title }}</h2>
              
            </a>
          </div>
        {% endif %}
      {%- endfor -%}


    
  </div>
</div>
<!-- End Product-Column-Custom  -->
{% schema %}
{
  "name": "Product-Column-Custom",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    }, {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 36
    }
  ],
  "blocks": [
  {
    "type": "product-custom",
    "name": "Product",
    "limit": 3,
    "settings": [
       {
          "type": "image_picker",
          "id": "img1",
          "label": "Product Image"
        },
    {
      "type": "text",
      "id": "text4",
      "label": "Text"
    },        
       {
          "type": "text",
          "id": "title",
          "label": "Product Title"
        },
        {
          "type": "url",
          "id": "linkproduct",
          "label": "Product Link"
        },
        {
          "type": "text",
          "id": "linkproductvariantid",
          "label": "Product Variant"
        },

    ]
  }
],
  "presets": [
    {
      "name": "Product Column Custom"
    }
  ]
}
{% endschema %}
