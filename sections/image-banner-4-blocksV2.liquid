{% comment %}
  Designed For Everyday (Dawn)
  - Background color only
  - Center richtext heading + center richtext text
  - 4 blocks: icon/image + richtext label
  - Mobile: autoplay carousel (1 card at a time)
  - Fully responsive (large desktop / 1920 / iPad / mobile)
{% endcomment %}

{%- liquid
  assign sid = section.id
-%}

<style>
  .dfe-{{ sid }}{
    width:100%;
    background: {{ section.settings.section_bg }};
  }

  .dfe-{{ sid }} .dfe__inner{
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    box-sizing: border-box;
    text-align: center;
  }

  .dfe-{{ sid }} .dfe__heading{
    margin: 0 0 {{ section.settings.space_under_heading }}px;
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size_desktop }}px;
    line-height: 1.05;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .dfe-{{ sid }} .dfe__text{
    margin: 0 auto;
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.text_size_desktop }}px;
    line-height: 1.55;
    max-width: {{ section.settings.text_max_width }}px;
  }

  /* ===== DESKTOP GRID ===== */
  .dfe-{{ sid }} .dfe__grid{
    margin-top: {{ section.settings.space_above_cards }}px;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: {{ section.settings.card_gap }}px;
    align-items: stretch;
      max-width: {{ section.settings.text_max_width }}px;
  margin-left: auto;
  margin-right: auto;
  }

.dfe-{{ sid }} .dfe__card{
  background: {{ section.settings.card_bg }};
  border-radius: {{ section.settings.card_radius }}px;
  padding: {{ section.settings.card_padding_y }}px {{ section.settings.card_padding_x }}px;
  box-sizing: border-box;
  border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
  display:flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;

  min-height: {{ section.settings.card_min_height }}px;
  height: 100%;            /* ✅ force equal height */
}

  .dfe-{{ sid }} .dfe__icon{
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    border-radius: 999px;
    background: {{ section.settings.icon_bg }};
    display:flex;
    align-items:center;
    justify-content:center;
    margin-bottom: {{ section.settings.space_under_icon }}px;
    overflow:hidden;
  }

  .dfe-{{ sid }} .dfe__icon img{
    width: 70%;
    height: 70%;
    object-fit: contain;
    display:block;
  }

  .dfe-{{ sid }} .dfe__label{
    color: {{ section.settings.card_text_color }};
    font-size: {{ section.settings.card_text_size_desktop }}px;
    line-height: 1.25;
  }

  .dfe-{{ sid }} .dfe__slide{
  width: 100%;
  height: 100%;
}

  /* ===== TABLET ===== */
  @media (max-width: 989px){
    .dfe-{{ sid }} .dfe__inner{
      padding-left: 18px;
      padding-right: 18px;
    }

    .dfe-{{ sid }} .dfe__heading{
      font-size: {{ section.settings.heading_size_tablet }}px;
    }

    .dfe-{{ sid }} .dfe__text{
      font-size: {{ section.settings.text_size_tablet }}px;
    }

    .dfe-{{ sid }} .dfe__grid{
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: {{ section.settings.card_gap_tablet }}px;
    }

    .dfe-{{ sid }} .dfe__label{
      font-size: {{ section.settings.card_text_size_tablet }}px;
    }
  }

  /* ===== MOBILE: AUTOPLAY CAROUSEL (1 card at a time) ===== */
  @media (max-width: 749px){
    .dfe-{{ sid }} .dfe__inner{
      padding: {{ section.settings.padding_top_mobile }}px 16px {{ section.settings.padding_bottom_mobile }}px;
    }

    .dfe-{{ sid }} .dfe__heading{
      font-size: {{ section.settings.heading_size_mobile }}px;
      margin-bottom: {{ section.settings.space_under_heading_mobile }}px;
    }

    .dfe-{{ sid }} .dfe__text{
      font-size: {{ section.settings.text_size_mobile }}px;
      max-width: 560px;
    }

/* MOBILE DEFAULT = STACK/GRID (when carousel disabled) */
.dfe-{{ sid }} .dfe__grid{
  margin-top: {{ section.settings.space_above_cards_mobile }}px;
  display:grid;
  grid-template-columns: 1fr;
  gap: {{ section.settings.card_gap_mobile }}px;
}

/* MOBILE CAROUSEL MODE (when enabled) */
.dfe-{{ sid }} .dfe__grid.is-carousel{
  display:flex;
  gap: {{ section.settings.card_gap_mobile }}px;
  overflow-x:auto;
  overflow-y:hidden;
  -webkit-overflow-scrolling: touch;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  padding: 0 0 10px;
  scrollbar-width: none;
}
.dfe-{{ sid }} .dfe__grid.is-carousel::-webkit-scrollbar{ display:none; }

.dfe-{{ sid }} .dfe__slide{
  width: 100%;
}

/* only in carousel mode: 1 slide at a time */
.dfe-{{ sid }} .dfe__grid.is-carousel .dfe__slide{
  flex: 0 0 100%;
  min-width: 100%;
  scroll-snap-align: center;
}
    .dfe-{{ sid }} .dfe__grid::-webkit-scrollbar{ display:none; }

    .dfe-{{ sid }} .dfe__slide{
      flex: 0 0 100%;
      min-width: 100%;
      scroll-snap-align: center;
    }

    .dfe-{{ sid }} .dfe__card{
      width: 100%;
      min-height: {{ section.settings.card_min_height_mobile }}px;
    }

    .dfe-{{ sid }} .dfe__label{
      font-size: {{ section.settings.card_text_size_mobile }}px;
    }
  }

  @media (prefers-reduced-motion: reduce){
    .dfe-{{ sid }} .dfe__grid{ scroll-behavior: auto; }
  }

  /* ===== Mobile dots (like design) ===== */
.dfe-{{ sid }} .dfe__dots{
  display:flex;
  align-items:center;
  justify-content:center;
  gap: 10px;
  margin-top: 16px;
}

.dfe-{{ sid }} .dfe__dot{
  appearance:none;
  border:0;
  padding:0;
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: rgba(255,255,255,0.45);
  cursor:pointer;
  transition: transform .2s ease, background .2s ease;
}

.dfe-{{ sid }} .dfe__dot[aria-current="true"]{
  background: rgba(255,255,255,0.95);
  transform: scale(1.15);
}

/* show dots only on mobile when carousel enabled */
@media (min-width: 750px){
  .dfe-{{ sid }} .dfe__dots{ display:none; }
}

@media (min-width: 750px){
  .dfe-{{ sid }}{ min-height: 722px; height:auto; }
  .dfe-{{ sid }} .dfe__inner{
    min-height: 722px;
    display:flex;
    flex-direction:column;
    justify-content:center;
  }
  .dfe-{{ sid }} .dfe__card{
  justify-content: flex-start; /* instead of center */
}

.dfe-{{ sid }} .dfe__icon{
  margin-bottom: 12px;
}

.dfe-{{ sid }} .dfe__label{
  flex-grow: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
/* padding for all cards text */
.dfe-{{ sid }} .dfe__label{
  padding: 8px;
  box-sizing: border-box;
}

/* optional: remove default richtext <p> spacing so it looks same in every card */
.dfe-{{ sid }} .dfe__label p{
  margin: 0;
}
}


</style>

<section class="dfe-{{ sid }}" data-dfe data-section-id="{{ sid }}">
  <div class="dfe__inner">
    {%- if section.settings.heading != blank -%}
      <div class="dfe__heading rte">{{ section.settings.heading }}</div>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <div class="dfe__text rte">{{ section.settings.text }}</div>
    {%- endif -%}

    <div class="dfe__grid" data-dfe-track aria-label="Designed for everyday features">
      {%- for block in section.blocks -%}
        {%- liquid
          assign icon = block.settings.icon
        -%}

        <div class="dfe__slide" data-dfe-slide {{ block.shopify_attributes }}>
          <div class="dfe__card">
            <div class="dfe__icon" aria-hidden="true">
              {%- if icon != blank -%}
                <img
                  src="{{ icon | image_url: width: 240 }}"
                  alt="{{ icon.alt | escape }}"
                  loading="lazy"
                  width="{{ icon.width }}"
                  height="{{ icon.height }}"
                >
              {%- endif -%}
            </div>

            {%- if block.settings.text != blank -%}
              <div class="dfe__label rte">{{ block.settings.text }}</div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.enable_mobile_carousel and section.blocks.size > 1 -%}
  <div class="dfe__dots" data-dfe-dots aria-label="Carousel pagination">
    {%- for block in section.blocks -%}
      <button
        type="button"
        class="dfe__dot"
        data-dfe-dot
        aria-label="Go to item {{ forloop.index }}"
        aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
      ></button>
    {%- endfor -%}
  </div>
{%- endif -%}
  </div>
</section>

<script>
(function(){
  var root = document.querySelector('[data-dfe][data-section-id="{{ sid }}"]');
  if(!root) return;

  var track = root.querySelector('[data-dfe-track]');
  var slides = Array.prototype.slice.call(root.querySelectorAll('[data-dfe-slide]'));
  var dotsWrap = root.querySelector('[data-dfe-dots]');
  var dots = dotsWrap ? Array.prototype.slice.call(root.querySelectorAll('[data-dfe-dot]')) : [];
  if(!track || slides.length < 2) return;

  var mobileMQ = window.matchMedia('(max-width: 749px)');
  var enableMobileCarousel = {{ section.settings.enable_mobile_carousel | json }};
  var autoplay = {{ section.settings.mobile_autoplay | json }};
  var speed = {{ section.settings.autoplay_speed | default: 3500 }};
  var timer = null;
  var index = 0;

  function setDot(i){
    if(!dots.length) return;
    dots.forEach(function(d, idx){
      d.setAttribute('aria-current', idx === i ? 'true' : 'false');
    });
  }

  function getClosestIndex(){
    var center = track.scrollLeft + track.clientWidth/2;
    var best = 0, bestDist = Infinity;

    slides.forEach(function(slide, i){
      var sc = slide.offsetLeft + slide.clientWidth/2;
      var d = Math.abs(sc - center);
      if(d < bestDist){ bestDist = d; best = i; }
    });

    return best;
  }

  function scrollToIndex(i){
    i = (i + slides.length) % slides.length;
    index = i;
    slides[i].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
    setDot(index);
  }

  function stop(){
    if(timer){ clearInterval(timer); timer = null; }
  }

  function start(){
    stop();
    if(!autoplay) return;
    timer = setInterval(function(){
      scrollToIndex(index + 1);
    }, speed);
  }

  function applyMode(){
    // Desktop/tablet always grid
    if(!mobileMQ.matches){
      track.classList.remove('is-carousel');
      stop();
      setDot(0);
      return;
    }

    // Mobile
    if(enableMobileCarousel){
      track.classList.add('is-carousel');
      // start from first
      index = getClosestIndex();
      setDot(index);
      start();
    } else {
      track.classList.remove('is-carousel');
      stop();
      setDot(0);
    }
  }

  // dot click
  if(dots.length){
    dots.forEach(function(dot, i){
      dot.addEventListener('click', function(){
        scrollToIndex(i);
      });
    });
  }

  // update on scroll (only in carousel mode)
  var ticking = false;
  track.addEventListener('scroll', function(){
    if(!mobileMQ.matches || !enableMobileCarousel) return;
    if(ticking) return;
    ticking = true;
    window.requestAnimationFrame(function(){
      index = getClosestIndex();
      setDot(index);
      ticking = false;
    });
  }, {passive:true});

  // pause autoplay while user interacts
  var pauseTimer = null;
  function pauseThenResume(){
    if(!mobileMQ.matches || !enableMobileCarousel) return;
    stop();
    if(pauseTimer) clearTimeout(pauseTimer);
    pauseTimer = setTimeout(function(){ start(); }, 1200);
  }
  track.addEventListener('touchstart', pauseThenResume, {passive:true});
  track.addEventListener('mousedown', pauseThenResume);

  mobileMQ.addEventListener ? mobileMQ.addEventListener('change', applyMode) : mobileMQ.addListener(applyMode);
  window.addEventListener('resize', applyMode);

  applyMode();
})();
</script>

