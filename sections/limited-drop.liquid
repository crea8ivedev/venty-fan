
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: calc({{ section.settings.padding_top }}px * 0.75);
    padding-bottom: calc({{ section.settings.padding_bottom }}px  * 0.75);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }


.limited-drop {
  padding: 60px 20px;
  background-image: url('https://cdn.shopify.com/s/files/1/0613/3297/9961/files/Frame_2.png?v=1759819838');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.limited-drop-top {
  text-transform: uppercase;
  letter-spacing: 1px;
  font-size: 19px;
  color: #818387;
}
.limited-drop-heading {
    font-size:84px;
    font-weight: normal;
    margin: 10px 0;
    color: #152B4F;
}
.limited-svg-title {
    display: grid;
    grid-template-columns: 1fr 5fr;
    column-gap: 15px;
    padding:15px 0;
    align-items: center;
}
.limited-svg-title p{
margin:0;
}
.limited-drop-heading strong{
    color: #2FBAAC;
}

.limited-drop-inner h2 + p {
    color: #152B4F;
    font-size: 26px;
    margin: 0 0 30px;
    font-weight: 500;
}
.limited-drop-sub {
  font-size: 16px;
  color: #333;
  margin-bottom: 30px;
}
.limited-drop-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 0;
    position: relative;
    align-items: center;
}




.limited-drop-dates p, .limited-drop-price p {
  margin: 0;
  font-size:24px; line-height:1.4;
}
.limited-drop-price .price {
    color: #fff;
}
p.after-text {
    font-size: 16px;
    color: #fff;
}

.price p {
    font-size:18px;
}


.price p strong{
    font-size:45px;
}



.limited-drop {
  position: relative; 
  overflow: hidden;
}




.limited-drop::after {
    content: "";
    position: absolute;
    right: 0;
    height: 200px;
    width:68%;
    top: auto;
    bottom: 55px;
    z-index: 1;
    padding: 0 30px 30px;
    color: #fff;
    background-color: #2FBAAC;
    border-radius: 30px 0 0 30px;
    display: block;
}



.limited-drop-images img {
    max-width: 100%;
    margin-bottom: -40px;
}
.limited-drop-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: flex-end;
    position: relative;
    z-index: 2;
}


.limited-svg-title:nth-child(1){
  position:relative;
}

.limited-svg-title:nth-child(1)::after {
  content: "";
  position:absolute;
  bottom:0; top:auto; left:0;
  display: block;
  width: 90%;
  margin: 5px auto 0;
  height: 1px;
  background: #818387;
}
.price p strong br{
  display:none;
}

.price p strong {
  position: relative;
  display:block; 
    margin: 0px auto 10px;
}
.price p strong::after{
   content: "";
  position:absolute;
  bottom:0; top:auto; left:0;
  display: block;
  width: 100%;
  margin: 5px auto -5px;
  height:5px;
    background-image: url('https://cdn.shopify.com/s/files/1/0613/3297/9961/files/Frame_4.png?v=1759837312');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

p.after-text {
    max-width: 160px;
}
.limited-drop-dates strong {
    color: #152B4F;
}

.limited-drop-dates {
    margin-right: 30px;
}

.price p {
    text-transform: uppercase;
}



@media (max-width:1599px) {

.limited-drop::after {
    width: 72%;
   
}
}
@media (max-width:1799px) {

.limited-drop::after {
    width: 73%;
   
}
}
@media (max-width:1399px) {

.limited-drop::after {
    width: 74%;
}

}

@media (max-width:1300px) {
.limited-drop-heading {
    font-size: 65px;
}

.price p{
    font-size:15px;
}
.limited-drop-dates p, .limited-drop-price p {
    margin: 0;
    font-size: 20px;
    line-height: 1.4;
}
.price p strong {
    font-size: 25px;
}

.limited-drop::after {
    width: 73%;
   
}

}



@media (max-width:1199px) {

.limited-drop-heading {
    font-size: 50px;
}
.limited-drop-inner h2 + p {
    color: #152B4F;
    font-size: 20px;
    margin: 0 0 30px;
}


.limited-drop-top {
    font-size: 16px;
    
}




}

@media (max-width:1024px) {


.limited-drop-dates {
    margin-right: 0;
}


.limited-drop-heading {
    font-size: 42px;
}
.limited-drop-dates p, .limited-drop-price p {
    margin: 0;
    font-size: 14px;
    line-height: 1.4;
}
.limited-svg-title {
     grid-template-columns: 1fr  18fr;
}

.limited-drop-inner h2 + p {
    font-size: 14px;
}
.limited-drop-top {
    font-size: 14px;
}

.price p strong {
    font-size: 20px;
}
.limited-drop::after {
    width: 73%;
    height: 145px;
}

.limited-drop-top {
    font-size: 12px;
}
.limited-drop-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

}



@media (max-width:667px) { 





.limited-drop-images img {
    max-width: 100%;
    margin-bottom: 0px;
}



  .limited-drop-info{
    position: unset;
  }


.limited-drop-images {
    position: unset;
    width:100%;
    height: 100%;
    padding-bottom: 35px;
}
.limited-drop-inner {
    display: flex;
    flex-direction: column-reverse;
}
.limited-drop {
    padding-left: 0;
    padding-right: 0;
}
.limited-drop-price {
    right: auto;
    left: 10px;
    top: 10px;
    width: fit-content;
    min-width: fit-content;
    border-radius: 20px;
    padding: 15px !important;
}

.limited-drop-dates p, .limited-drop-price p {
    margin: 0;
    font-size: 12px;
    line-height: 1.4;
}

.limited-drop-price {
    right: auto;
    left: 10px;
    top: 0;
    width: auto;
    min-width: 140px;
    border-radius: 20px;
    padding: 15px !important;
    max-width: 100px;
    background: #24c5ae;
    position: absolute;
}
.limited-drop-top {
    font-size: 12px;
}
.limited-svg-title p {
    font-size: 20px;
}
.limited-drop-info{
   margin: 0;
}


.limited-drop::after{

display:none;
}
.limited-drop-info {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
}


}
@media only screen and (max-width: 500px) {
    .limited-drop .page-width {
    padding: 0 1.5rem !important;
}
}



{%- endstyle -%}


