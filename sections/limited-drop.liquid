      <div class="limited-drop-price">
         <div class="limited-drop-price-part">
        {% if section.settings.price != blank %}
          <div class="price">{{ section.settings.price }}</div>
        {% endif %}
        {% if section.settings.after_price_text != blank %}
          <p class="after-text">{{ section.settings.after_price_text }}</p>
        {% endif %}
        </div>
      </div>
