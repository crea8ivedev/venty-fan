{% schema %}
{
  "name": "Limited Drop Section",
  "settings": [
    {
      "type": "text",
      "id": "top_text",
      "label": "Top Small Text",
      "default": "STAY COOL—CLAIM YOURS BEFORE THEY’RE GONE."
    },
    {
      "type": "richtext",
      "id": "main_heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "sub_text",
      "label": "content"
    },
    {
      "type": "richtext",
      "id": "preorder_date",
      "label": "Preorders Go Live Date"
    },
    {
      "type": "richtext",
      "id": "shipping_date",
      "label": "Fans Ship Date",
    },
    {
      "type": "richtext",
      "id": "price",
      "label": "Pre-order Price"
    },
    {
      "type": "text",
      "id": "after_price_text",
      "label": "After 500 Price Text",
      "default": "After the first 500 are gone, price goes up to $99.99."
    },
    {
      "type": "image_picker",
      "id": "product_image_1",
      "label": "Product Image"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Limited Drop Promo"
    }
  ]
}
{% endschema %}
