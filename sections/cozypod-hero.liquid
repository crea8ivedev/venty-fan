{% style %}
/* ================= HERO ================= */
*{
    font-family: Montserrat !important;
}
p,h1{
  margin:0;
}
.drawer{
  display:none !important;
}
.cozypod-hero {
  position: relative;
  color: #fff;
  /* height: 100vh; */
}
.cozypod-hero_wrapper {
    max-width: 450px;
    width: 100%;
}
.cozypod-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
}

.cozypod-hero__bg-image {
  width: 100%;
  object-fit: fill;
  height: 1100px;
  /* min-height: 1154px;
  max-height:1154px;
  object-position: center bottom; */
}
.cozypod-hero__bg-mobile{
  display: none;
  position: absolute;
  inset: 0;
  z-index: 0;
  margin-bottom: -9px;
}

@media (min-width: 1600px) {
  .cozypod-hero__bg-image {
    height: 1200px;
  } 
}

.cozypod-hero__content {
  position: relative;
  z-index: 1;
  transform: translatey(60%);
}

.cozypod-hero__text {
display: flex;
justify-content: space-between;
align-items: center;
}

.cozypod-hero__text h1 {
  font-family: Montserrat;
  font-weight: 400;
  font-size: 80px;
  line-height: 86px;
  text-transform: uppercase;
  color: #fff;
  margin-bottom: 10px;
}

.cozypod-hero__text p {
  font-weight: 400;
  font-size: 24px;
  max-width: 319px;
  line-height: 34px;
}
.form_text p {
    font-size: 19px;
}

.form_text {
  box-shadow: 0 4px 80px rgba(0,0,0,.5);
  backdrop-filter: blur(50px);
  padding: 37px 28px 49px 26px;
  border-radius: 20px;
  max-width: 370px;
  width: 100%;
}

.cozypod-hero__heading {
  font-size: 80px;
  line-height: 110px;
  text-transform: uppercase;
  color: #fff;
}

.hero-word--bold {
  font-weight: 700;
}

.hero-word--normal {
  font-weight: 400;
}

.cozypod-hero__form {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 20px;
}

.cozypod-hero__form input {
  padding: 14px 20px;
  border-radius: 30px;
  border: none;
  background: #363636;
  font-size: 15px;
  line-height: 34px;
  color: #fff;
}

.cozypod-hero__form input:focus-visible {
  outline: none;
  box-shadow: none;
  outline-offset: unset;
}

.cozypod-hero__form button, .cozypod-form__button { 
  padding: 13px 0px 13px 0px;
  border-radius: 30px;
  background: #ff7a00;
  color: #fff;
  border: none;
  font-weight: 600;
  cursor: pointer;
  font-size: 14px;
  line-height: 34px;
}



.cozypod-popup {
  position: fixed;
  inset: 0;
  display: none;
  z-index: 9999;
}

.cozypod-popup.is-open {
  display: flex;
  align-items: center;
  justify-content: center;
}

.cozypod-popup__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.6);
}

.cozypod-popup__box {
  position: relative;
  background: #fff;
  max-width: 960px;
  width: 92%;
  border-radius: 16px;
  padding: 40px;
  z-index: 2;
}
button.cozypod-popup__close {
    z-index: 9;
}

.cozypod-popup__close {
  position: absolute;
  top: 14px;
  right: 16px;
  font-size: 26px;
  background: none;
  border: none;
  cursor: pointer;
}

.cozypod-popup__grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 40px;
  align-items: center;
}
.popup-old-price span {
    line-height: 32px;
}

.cozypod-popup__content{
  position: relative;
  z-index: 2;
  color: #000;
}
.cozypod-popup__content h2 {
  font-size: 42px;
  margin-bottom: 8px;
  font-weight: 700;
  line-height: 16px;
}

.popup-subtitle {
  font-size: 32px;
  margin-bottom: 24px;
  color: #000;
}

.popup-price {
  margin-bottom: 22px;  
}

.popup-old-price span {
  text-decoration: line-through;
  font-size: 40px;
  display: inline-block;
  margin-top: 4px;
 
}

.popup-launch {
  margin-top: 16px;
  line-height: 23px;
  font-size: 20px;
  line-height: 30px;
}

.popup-new-price {
  font-size: 40px;
  font-weight: 700;
  margin-top: 14px;
}

.popup-cta {
  display: inline-block;
  background: #e66a00;
  color: #fff;
  padding: 14px 28px;
  border-radius: 999px;
  text-decoration: none;
  font-weight: 600;
  font-size: 13px;
  text-align: center;
}

.cozypod-popup__image {
  position: absolute;
  right: 0;
}
.cozypod-popup__image img {
  width: 603px;
  height: auto;
}

@media (max-width: 992px) {
  .cozypod-hero__text h1 {
    font-size: 60px;
    line-height: 64px;
  }
  .cozypod-hero__text p{
    font-size: 18px;
    line-height: 24px;
  }
}

@media (max-width: 768px) {
  .cozypod-popup__grid {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .cozypod-popup__box {
    padding: 24px;
    box-shadow: 1px 3px 13px #00000091;
  }
}
p {
  margin: 0;
}
.cozypod-hero__logo {
position: absolute;
top: 40px;
left: 50%;
transform: translateX(-50%);
z-index: 2;
text-align: center;
}

.cozypod-hero__logo img {
max-width: 110px; /* Figma width */
height: auto;
}
.hero-mobile-wrapper{
  display: none;
}

.popup-old-price {
    font-size: 20px;
    line-height: 30px;
}

/* Mobile adjustment */
@media (max-width: 768px) {
   .cozypod-hero__bg-mobile{
    display: block;
    position: relative;
  }
  .cozypod-hero__bg{
    display: none;
  }
  .cozypod-hero__bg-image {
    object-fit: cover;
    height: 740px;
    object-position: bottom;
  }
  .cozypod-hero__text{
    justify-content: center;
  }
  .cozypod-hero__content {
    background-color:#000000;
    transform: unset;
    position:static;
  }
  .cozypod-hero_wrapper{
    display: block;
    position: absolute;
    top: 126px;
    left: 0;
    right: 0;
    margin: auto;
  }
  .hero-mobile-wrapper{
    display: block;
    text-align: center;
    padding-top: 40px;
    margin:0 auto;
  }
  /* .form_text{
    display: none;
  } */
  .cozypod-hero__text h1{
    font-size:38px;
    line-height: 40px;
    margin-bottom: 10px;
    text-align: center;
  }
  .cozypod-hero__text p{
    font-size:14px;
    line-height: 20px;  
    text-align: center;
    margin:0 auto;
    text-transform: uppercase;
  }
  
  .cozypod-hero__logo {
    width: 100%;
    /* background-color: #2B2B2B; */
    top: 0;
    /* box-shadow: 0px 5px 4px 0px #00000080; */
  }
  .cozypod-hero__logo img {
    max-width: 100px;
    padding: 20px 0;
  }
  .cozypod-hero__form button, .cozypod-form__button {
    box-shadow: 0px 4px 4px 0px #00000040;
  }
  .cozypod-hero__form input{
    background-color: #eee;
    color: #000;  
  }
  .cozypod-popup__image{
    display: none;
  }
}
@media (max-width: 640px) {
  .cozypod-hero__bg-image{
    height: 544px;
  }
}


{% endstyle %}

<section class="cozypod-hero">

<!-- Background -->
  <div class="cozypod-hero__bg">
    {% if section.settings.bg_image %}
      <img
        src="{{ section.settings.bg_image | image_url: width: 2000 }}"
        class="cozypod-hero__bg-image"
        alt=""
        width="{{ section.settings.bg_image.width }}"
        height="{{ section.settings.bg_image.height }}"
        loading="eager"
      >
    {% endif %}
  </div>
  <div class="cozypod-hero__bg-mobile">
     {% if section.settings.bg_image_mobile %}
    <img
      src="{{ section.settings.bg_image_mobile | image_url: width: 2000 }}"
      class="cozypod-hero__bg-image"
      alt=""
      width="{{ section.settings.bg_image_mobile.width }}"
      height="{{ section.settings.bg_image_mobile.height }}"
      loading="eager"
    >
      {% endif %}
  </div>

<!-- Content -->
<div>
 {% if section.settings.hero_logo %}
    <div class="cozypod-hero__logo">
      <a href="/">
      <img
        src="{{ section.settings.hero_logo | image_url: width: 300 }}"
        alt="{{ section.settings.hero_logo.alt | escape }}"
        width="{{ section.settings.hero_logo.width }}"
        height="{{ section.settings.hero_logo.height }}"
        loading="eager"
      >
        </a>
    </div>
  {% endif %}
<div class="page-width cozypod-hero__content">
  <div class="cozypod-hero__text">
    <div class="cozypod-hero_wrapper">
      {% comment %} <h1 class="cozypod-hero__heading">
        <span class="hero-word hero-word--bold">
          {{ section.settings.word_plug }}
        </span>
        <span class="hero-word hero-word--normal">
          {{ section.settings.word_in_get }}
        </span>
        <span class="hero-word hero-word--bold">
          {{ section.settings.word_cozy }}
        </span>
      </h1> {% endcomment %}
        <h1 class="cozypod-hero__heading">
            <strong>PLUG</strong> IN. GET <strong>COZY.</strong>
        </h1>
      <p>{{ section.settings.subheading }}</p>
    </div>
   

    <!-- Email + Button -->
    <div class="form_text">
      <p>{{ section.settings.joinus }}</p>

      {% comment %} <form class="cozypod-hero__form" id="heroEmailForm">
        <input
          type="email"
          id="heroEmailInput"
          placeholder="{{ section.settings.email_placeholder }}"
          required
          class="cozypod_email-input"
        >
        <div class="status"></div>
        <button type="button" class="cozypod-popup-trigger cozypod-form__button">
          {{ section.settings.button_label }}
        </button>
      </form> {% endcomment %}

      {% if section.settings.show_signup_form %}
        <form method="POST" class="cozypod-hero__form" id="custom-klaviyo-form">
          <input type="hidden" name="g" value="XS4Mrc">
          <input id="heroEmailInput" type="email" name="email"  placeholder="{{ section.settings.email_placeholder }}" class="cozypod_email-input" required>
          <div class="status"></div>
          <button
            type="submit"
            class="cozypod-popup-trigger cozypod-form__button"
          >
            {{ section.settings.button_label }}
          </button>
        </form> 

        {% comment %} <form method="POST" id="custom-klaviyo-form">
          <input type="hidden" name="g" value="XS4Mrc">
          <label for="email">Email:</label>
          <input type="email" name="email" id="email" placeholder="your@email.com" required>
          <!-- Optional: Add more fields, e.g., first name -->
          <!-- <label for="first_name">First Name:</label> -->
          <!-- <input type="text" name="$fields[first_name]" value=""> -->
          <button type="submit">Subscribe</button>
        </form> {% endcomment %}
        <!-- Recommended: Include this script for AJAX submission (no page reload) and better features -->
        <script type="text/javascript" src="https://www.klaviyo.com/media/js/public/klaviyo_subscribe.js"></script>
        <script type="text/javascript">
          KlaviyoSubscribe.attachToForms('#custom-klaviyo-form', {
            hide_form_on_success: true,
            success_message: "Thanks for subscribing!",

           success: function($form) {

              setTimeout(() => {
                const popup = document.getElementById('cozypodPopup');
                if (popup) popup.classList.add('is-open');   
              }, 500);
              return false;
            }
          });
        </script>
      {% else %}
        <div class="cozypod-hero__form">
          <a href="{{ section.settings.alt_button_link }}" class="cozypod-form__button" target="_blank" style="text-align: center; text-decoration: none;">
            {{ section.settings.alt_button_text }}
          </a>
        </div>
      {% endif %}

    </div>

  </div>
</div>
</div>
</section>

 
{% schema %}
{
"name": "Cozypod Hero",
"settings": [
  { "type": "image_picker", "id": "hero_logo", "label": "Hero logo (top center)" },
  { "type": "image_picker", "id": "bg_image", "label": "Background image" },
  { "type": "image_picker", "id": "bg_image_mobile", "label": "Background image mobile" },
  { "type": "text", "id": "word_plug", "label": "Heading – PLUG (bold)", "default": "PLUG" },
  { "type": "text", "id": "word_in_get", "label": "Heading – IN. GET (normal)", "default": "IN. GET" },
  { "type": "text", "id": "word_cozy", "label": "Heading – COZY. (bold)", "default": "COZY." },
  { "type": "textarea", "id": "subheading", "label": "Subheading" },
  { "type": "textarea", "id": "joinus", "label": "Join us text" },
  { "type": "text", "id": "email_placeholder", "label": "Email placeholder", "default": "Email address" },
  { "type": "text", "id": "button_label", "label": "Button text", "default": "Sign up to See Launch Day Pricing" },
  { "type": "checkbox", "id": "show_signup_form", "label": "Show sign up form", "default": true },
  { "type": "text", "id": "alt_button_text", "label": "Alternative button text", "default": "Learn More" },
  { "type": "url", "id": "alt_button_link", "label": "Alternative button link" }

],
"presets": [
  { "name": "Cozypod Hero" }
]
}
{% endschema %}
