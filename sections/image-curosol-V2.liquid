      "type": "header",
      "content": "Button (global style)"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button text color",
      "default": "#D46B00"
    },
{
  "type": "range",
  "id": "button_radius",
  "label": "Button radius (px)",
  "min": 0,
  "max": 1000,
  "step": 10,
  "default": 1000
},
    {
      "type": "range",
      "id": "button_font_size",
