      "type": "range",
      "id": "dots_spacing_top",
      "label": "Space above dots (px)",
      "min": 6,
      "max": 50,
      "step": 2,
      "default": 18
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
