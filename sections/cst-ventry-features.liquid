<div class="cst-ventry-features-main scroll-trigger animate--slide-in">
<div class="cst-ventry-features">
<div class="ventry-features">
  <div class="ventry-wrapper">

    <!-- LEFT SIDE -->
    <div class="ventry-left">
        <div class="ventry-left-lists">
            <ul class="ventry-list">
                <li class="active" data-index="0">{{ section.settings.text1 }}</li>
                <li data-index="1">{{ section.settings.text2 }}</li>
                <li data-index="2">{{ section.settings.text3 }}</li>
                <li data-index="3">{{ section.settings.text4 }}</li>
                <li data-index="4">{{ section.settings.text5 }}</li>        
            </ul>
            <ul class="ventry-list-inner">
                <li data-index="5">{{ section.settings.text6 }}</li>
            </ul>
        </div>
      <div class="ventry-line">
        <div class="ventry-indicator"></div>
      </div>
    </div>


    <!-- MIDDLE TEXT -->
    <div class="ventry-content">

      <div class="ventry-text active">
        {{ section.settings.content1 }}
      </div>

      <div class="ventry-text">
        {{ section.settings.content2 }}
      </div>

      <div class="ventry-text">
        {{ section.settings.content3 }}
      </div>

      <div class="ventry-text">
       {{ section.settings.content4 }}
      </div>

      <div class="ventry-text">
        {{ section.settings.content5 }}
      </div>

      <div class="ventry-text">
        <div class="ventry-colors">
            <span class="color-dot" data-img="0" style="background:#8b1d2c"></span>
            <span class="color-dot" data-img="1" style="background:#cfcfcf"></span>
            <span class="color-dot active" data-img="2" style="background:#333"></span>
        </div>
      </div>

    </div>


    <!-- RIGHT SIDE -->
    
    <div class="ventry-images">
        <div class="ventry-images-top-content">
            <h3>Included Remote</h3>
            <h3>Upgraded Backlit Rechargeable Remote ($25)</h3>
        </div>

        <div class="ventry-images-black" style="display: block;">
            {% if section.settings.image1 != blank %}
                <img class="ventry-img active" data-label="0" src="{{ section.settings.image1 | img_url : 'master' }}" alt="{{ section.settings.image1.alt }}">
            {% endif %}
            {% if section.settings.image2 != blank %}        
                <img class="ventry-img" data-label="1" src="{{ section.settings.image2 | img_url : 'master' }}" alt="{{ section.settings.image2.alt }}" />
            {% endif %}
            {% if section.settings.image3 != blank %}             
                <img class="ventry-img" data-label="2" src="{{ section.settings.image3 | img_url : 'master' }}" alt="{{ section.settings.image3.alt }}" />
            {% endif %}
            {% if section.settings.image4 != blank %}             
                <img class="ventry-img" data-label="3" src="{{ section.settings.image4 | img_url : 'master' }}" alt="{{ section.settings.image4.alt }}" />
            {% endif %}
            {% if section.settings.image5 != blank %}             
                <img class="ventry-img" data-label="4" src="{{ section.settings.image5 | img_url : 'master' }}" alt="{{ section.settings.image5.alt }}" />
            {% endif %}               
        </div>
        <div class="ventry-images-white" style="display: none;">
            {% if section.settings.whiteimage1 != blank %}
                <img class="ventry-img active" data-label="0" src="{{ section.settings.whiteimage1 | img_url : 'master' }}" alt="{{ section.settings.whiteimage1.alt }}">
            {% endif %}
            {% if section.settings.whiteimage2 != blank %}        
                <img class="ventry-img" data-label="1" src="{{ section.settings.whiteimage2 | img_url : 'master' }}" alt="{{ section.settings.whiteimage2.alt }}" />
            {% endif %}
            {% if section.settings.whiteimage3 != blank %}             
                <img class="ventry-img" data-label="2" src="{{ section.settings.whiteimage3 | img_url : 'master' }}" alt="{{ section.settings.whiteimage3.alt }}" />
            {% endif %}
            {% if section.settings.whiteimage4 != blank %}             
                <img class="ventry-img" data-label="3" src="{{ section.settings.whiteimage4 | img_url : 'master' }}" alt="{{ section.settings.whiteimage4.alt }}" />
            {% endif %}
            {% if section.settings.whiteimage5 != blank %}             
                <img class="ventry-img" data-label="4" src="{{ section.settings.whiteimage5 | img_url : 'master' }}" alt="{{ section.settings.whiteimage5.alt }}" />
            {% endif %}               
        </div>
        <div class="ventry-images-red" style="display: none;">
            {% if section.settings.redimage1 != blank %}
                <img class="ventry-img active" data-label="0" src="{{ section.settings.redimage1 | img_url : 'master' }}" alt="{{ section.settings.redimage1.alt }}">
            {% endif %}
            {% if section.settings.redimage2 != blank %}        
                <img class="ventry-img" data-label="1" src="{{ section.settings.redimage2 | img_url : 'master' }}" alt="{{ section.settings.redimage2.alt }}" />
            {% endif %}
            {% if section.settings.redimage3 != blank %}             
                <img class="ventry-img" data-label="2" src="{{ section.settings.redimage3 | img_url : 'master' }}" alt="{{ section.settings.redimage3.alt }}" />
            {% endif %}
            {% if section.settings.redimage4 != blank %}             
                <img class="ventry-img" data-label="3" src="{{ section.settings.redimage4 | img_url : 'master' }}" alt="{{ section.settings.redimage4.alt }}" />
            {% endif %}
            {% if section.settings.redimage5 != blank %}             
                <img class="ventry-img" data-label="4" src="{{ section.settings.redimage5 | img_url : 'master' }}" alt="{{ section.settings.redimage5.alt }}" />
            {% endif %}               
        </div>                
    </div>

  </div>
</div>
</div>
</div>
<style>
  .cst-ventry-features-main{padding: 0px 35px;  }
  .cst-ventry-features{  max-width:1254px;   margin: 0px auto;      
  }
  .ventry-features{
      padding:96px 52px;
      background: linear-gradient(270deg, rgb(235 235 235 / 30%) 0%, rgb(133 133 133 / 20%) 132.7%);
      border-radius: 67px;
  }

  .ventry-wrapper{
      display:flex;
      gap:40px;
      position: relative;
  }

  .ventry-left{
      display:flex;
      align-items:flex-start;
      justify-content: space-between;
      max-width: 250px;
      width: 100%;
  }

  .ventry-list{
      list-style:none;
      padding:0;
      margin:0;
      width: 100%;
  }
  .ventry-line:before {
      content: "";
      border: 1px solid #000000;
      width: 10px;
      height: 10px;
      display: block;
      border-radius: 50%;
      position: absolute;
      left: -4px;
      top: -10px;
  }
  .ventry-line:after {
      content: "";
      border: 1px solid #000000;
      width: 10px;
      height: 10px;
      display: block;
      border-radius: 50%;
      position: absolute;
      left: -4px;
      bottom: -10px;
  }
  ul.ventry-list-inner {
      margin: 0px;
      padding: 0px;
      list-style: none;
  }
  .ventry-list-inner li,
  .ventry-list li{
      margin: 0px 0 18px 0;
      cursor: pointer;
      font-size: 16px;
      line-height: 100%;
      color: rgba(145, 145, 145, 1);
      font-weight: 700;
      transition:0.3s;
      min-height: 100px;
      max-width: 145px;
  }

  .ventry-list li.active{
      color:#000;
      font-weight:700;
  }

  .ventry-content{ max-width:420px;}
  .ventry-text{
        margin-bottom: 18px;
        color: #8a8a8a;
        transition: 0.3s;
        font-weight: 500;
        font-size: 16px;
        line-height: 24px;  
        min-height: 100px;  
    }

    .ventry-text.active{
        display:block;
    }

    .ventry-images img{
      max-width: 400px;
      vertical-align: middle;
      margin: 0 auto;
      width: 100%;
          margin-top: 20px;
    }

    .ventry-text.active{
        color:#000;
        font-weight:500;
    }

    .ventry-images{
        position:relative;
        width:100%;
    }

    .ventry-img{
        position:absolute;
        top: 70px;
        left:0;
        right: 0;
        opacity:0;
        {% comment %} transition:opacity .4s ease; {% endcomment %}
    }
    .ventry-images-top-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .ventry-images-top-content h3 {
        margin: 0px;
        font-weight: 400;
        text-align: center;
        font-size: 16px;
        line-height: normal;
        letter-spacing: 0%;
        color: rgba(116, 116, 116, 1);
    }
    .ventry-img.active{
        opacity:1;
    }
    .ventry-line{
        width:1px;
        height:100%;
        background:#000000;
        position:relative;
        border-radius:4px;
        display: block;
    }

    .ventry-indicator{
        position:absolute;
        display: block !important;
        width:18px;
        height:87px;
        background:#888;
        background: linear-gradient(180deg, #5E5E5E 0%, #C4C4C4 80.1%);
        border: 1px solid rgba(48, 48, 48, 1);
        left:-8px;
        top:0;
        border-radius:10px;
        transition:top .35s ease;
    }
    .ventry-colors{
        display:flex;
        gap:10px;
        margin-top:15px;
    }

    .color-dot{
        width:31px;
        height:31px;
        border-radius:50%;
        cursor:pointer;
        border:2px solid transparent;
    }

    .color-dot.active{
        border-color:#000;
    }


    .ventry-text:last-child {
        margin: 0px;
        min-height: unset;
    }

    ul.ventry-list-inner li {
        min-height: unset;
        margin-bottom: 0px;
    }
    {% comment %} .ventry-list li:last-child {
        margin: 0px;
    } {% endcomment %}



    @media(max-width:1600px){
      .ventry-features {
        padding: 60px 40px
      }
      .ventry-text {
        margin-bottom: 10px;
      }
      .ventry-list-inner li, .ventry-list li {
        min-height: 90px;
      }
      .ventry-images img {
        max-width: 350px;
      }
    }



@media(max-width:1024px){
  .ventry-left{
        max-width: 160px;
    }
  .ventry-content {
      max-width: 360px;
  }
}


@media(max-width:989px){ 
    .ventry-features {
        padding: 80px 0px;
        background: transparent;
        border-radius: 0;      
        min-height: 1500px;
        height: 100%;
    }  
    .ventry-left {
        max-width: 100%;
        width: calc(30% - 20px);
    }  
    .ventry-content {
        max-width: 100%;
        width: calc(70% - 20px);
    }  
    .ventry-wrapper {
        gap: 40px;
        flex-wrap: wrap;
        row-gap: 60px;
    }  

}


@media(max-width:768px){ 
  .ventry-list li {
      font-weight: 700;
      font-size: 16px;
      line-height: 100%;
      letter-spacing: -3%;
  }  
  .ventry-text p {
      font-weight: 500;
      font-size: 15px;
      line-height: 17px;
      letter-spacing: -3%;
  }
}

@media(max-width:590px){ 
  .ventry-left {
      max-width: 100%;
      width: calc(40% - 12px);
  }
  .ventry-content {
      max-width: 100%;
      width: calc(60% - 12px);
  }    
  .ventry-wrapper {
      gap: 24px;
  }  
  .ventry-features {
      min-height: 1410px;
  }  
  .ventry-images img {
      max-width: 350px;
  }


}

@media(max-width:420px){ 
.ventry-left {
  width: calc(45% - 12px);
}
.ventry-content {
  width: calc(55% - 12px);
}
}

</style>


