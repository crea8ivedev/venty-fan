document.addEventListener('DOMContentLoaded', function() {
    const colorDots = document.querySelectorAll('.color-dot');

    const ventryImages = document.querySelectorAll('.ventry-images-red, .ventry-images-white, .ventry-images-black');

    colorDots.forEach(function(colorDot, index) {
        colorDot.addEventListener('click', function() {
            colorDots.forEach(function(dot) {
                dot.classList.remove('active');
            });

            colorDot.classList.add('active');

            ventryImages.forEach(function(image) {
                image.style.display = 'none';
            });

            if (index === 0) {
                document.querySelector('.ventry-images-red').style.display = 'block';
            } else if (index === 1) {
                document.querySelector('.ventry-images-white').style.display = 'block';
            } else if (index === 2) {
                document.querySelector('.ventry-images-black').style.display = 'block';
            }
        });
    });
}); 
</script>


