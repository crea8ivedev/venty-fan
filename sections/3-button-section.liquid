{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  
  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mob }}px;
      padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    }
  }
{%- endstyle -%}
<style>
  .three-btn-section .page-width {
    gap: 50px;
    display: flex;
    justify-content: center;
}
.three-btn-section .page-width a {
    color: rgba(77, 77, 77, 1);
    font-size: 18px;
    font-weight: 500;
    line-height: 25.08px;
    text-align: center;
    text-decoration: none;
    text-transform: capitalize;
    border: 1px solid rgba(77, 77, 77, 1);
    border-radius: 6px;
    padding: 20px 50px;
}

  @media(max-width:768px){
    .three-btn-section .page-width {
    gap: 13px;
    flex-wrap: wrap;
}
    .three-btn-section .page-width a {
    width: 100%;
}
}
  
</style>

        <div class="section-{{ section.id }}-padding three-btn-section">
  <div class="page-width">
        {% if section.settings.button_text_1 != blank %}
 <a href=" {{ section.settings.button_link_1 }}"> <h6> {{ section.settings.button_text_1 }}  </h6>
<p> {{ section.settings.button_content_1 }} </p>
 </a>
{% endif %}
           {% if section.settings.button_text_2 != blank %}
 <a href=" {{ section.settings.button_link_2 }}"><h6> {{ section.settings.button_text_2 }}</h6>
 <p> {{ section.settings.button_content_2 }} </p>
 </a>
{% endif %}
           {% if section.settings.button_text_3 != blank %}
 <a href=" {{ section.settings.button_link_3 }}"><h6> {{ section.settings.button_text_3 }}</h6>
 <p> {{ section.settings.button_content_3 }} </p>
 </a>
{% endif %}
               
  </div>
</div>
       
{% schema %}
    {
    "name": "Custom 3 button Section",
    "settings": [

              {
                  "type": "text",
                    "id": "button_text_1",
                  "label":"Button Text 1"
                }, 
               {
                  "type": "text",
                    "id": "button_content_1",
                  "label":"Button content 1"
                }, 
                  {
                "type": "url",
                "id": "button_link_1",
                "label": "Button Url 1"
            },
           {
                  "type": "text",
                    "id": "button_text_2",
                  "label":"Button Text 2"
                }, 
                 {
                  "type": "text",
                    "id": "button_content_2",
                  "label":"Button content 2"
                },
                  {
                "type": "url",
                "id": "button_link_2",
                "label": "Button Url 2"
            },
       {
                  "type": "text",
                    "id": "button_text_3",
                  "label":"Button Text 3"
                }, 
               {
                  "type": "text",
                    "id": "button_content_3",
                  "label":"Button content 3"
                },
                  {
                "type": "url",
                "id": "button_link_3",
                "label": "Button Url 3"
            }, {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 36
    }
      
    ],
 
    "presets": [
    {
      "name": "Custom 3 button Section"
    }
  ]
  }
{% endschema %}
{% stylesheet %}
{% endstylesheet %}

