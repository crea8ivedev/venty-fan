{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mob }}px;
      padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    }
  }
{%- endstyle -%}

<style>
  .cstm-s-product-paragraphs h2 {
    color: rgba(0, 0, 0, 1);
    font-size: 30px;
    font-weight: 500;
    line-height: 36.48px;
    text-align: left;
    margin: 0;
    margin-bottom: 40px;
}
.cstm-s-pro-para-main {
    display: flex;
    flex-wrap: wrap;
  justify-content:space-between;
}
.cstm-s-pro-para {
    border-bottom: 1px solid rgba(204, 205, 206, 1);
    padding: 23px 0;
    width: 29%;
    color: rgba(128, 129, 131, 1);
    font-size: 17px;
    font-weight: 400;
    line-height: 25.92px;
    text-align: left;
}
  @media(max-width:800px){
    .cstm-s-pro-para {
    width: 48%;
}
  }
  @media(max-width:500px){
  .cstm-s-pro-para {
    border-bottom: 1px solid rgba(204, 205, 206, 1);
    padding: 18px 0;
    width: 100%;
    color: rgba(128, 129, 131, 1);
    font-size: 17px;
    font-weight: 400;
    line-height: 25.92px;
    text-align: left;
}
}
</style>











<div class="section-{{ section.id }}-padding cstm-s-product-paragraphs">
  <div class="page-width">
    <h2>{{ section.settings.heading }}</h2>
      <div class="cstm-s-pro-para-main">
    {% for block in section.blocks %}
      <div class="cstm-s-pro-para">
      {{ block.settings.paragrph }}
      </div>
    {% endfor %}
  </div>
  </div>
</div>
{% schema %}
  {
  "name": "Custom Sproduct Paragraph",
  "settings": [

  {
    "type": "text",
    "id": "heading",
    "label": "Heading"
  },
    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 36
    }

  ],
  "blocks":[
	 {

             "type": "paragraph",
              "name": "Paragraph",
              "settings": [


                 {
                "type": "text",
                  "id": "paragrph",
                "label":"Paragrph"
              }

              ]
           }
  ],
  "presets": [
  {
    "name": "Custom Sproduct Paragraph"
  }
]
}
{% endschema %}
{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}
