<script>
document.addEventListener("DOMContentLoaded", function() {
  // ------------------- COUNTDOWN -------------------
  var endDate = new Date("{{ section.settings.end_date }}").getTime();
  var timer = setInterval(function() {
    var now = new Date().getTime();
    var distance = endDate - now;

    if (distance < 0) {
      clearInterval(timer);
      document.getElementById("countdown-{{ section.id }}").innerHTML = "EXPIRED";
      return;
    }

    var days = Math.floor(distance / (1000 * 60 * 60 * 24));
    var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    var seconds = Math.floor((distance % (1000 * 60)) / 1000);

    document.getElementById("days-{{ section.id }}").innerText = days < 10 ? "0" + days : days;
    document.getElementById("hours-{{ section.id }}").innerText = hours < 10 ? "0" + hours : hours;
    document.getElementById("minutes-{{ section.id }}").innerText = minutes < 10 ? "0" + minutes : minutes;
    document.getElementById("seconds-{{ section.id }}").innerText = seconds < 10 ? "0" + seconds : seconds;
  }, 1000);


  // ------------------- SLIDER -------------------
  var slider = document.querySelector("#slider-{{ section.id }} .slides");
  var slides = document.querySelectorAll("#slider-{{ section.id }} .slide");
  var dotsContainer = document.getElementById("dots-{{ section.id }}");
  var index = 0;
  var autoSlideInterval;
  var isDragging = false;
  var startPos = 0;
  var currentTranslate = 0;
  var prevTranslate = 0;
  var animationID;
  var currentIndex = 0;

  // Create dots dynamically
  slides.forEach((_, i) => {
    const dot = document.createElement("button");
    dot.addEventListener("click", function() {
      index = i;
      updateSlider();
      resetAutoSlide();
    });
    dotsContainer.appendChild(dot);
  });

  function updateSlider() {
    slider.style.transition = "transform 0.4s ease";
    slider.style.transform = `translateX(-${index * 100}%)`;
    dotsContainer.querySelectorAll("button").forEach((btn, i) => {
      btn.classList.toggle("active", i === index);
    });
  }

  function nextSlide() {
    index = (index + 1) % slides.length;
    updateSlider();
  }

  function prevSlide() {
    index = (index - 1 + slides.length) % slides.length;
    updateSlider();
  }

  function startAutoSlide() {
    autoSlideInterval = setInterval(nextSlide, 4000);
  }

  function resetAutoSlide() {
    clearInterval(autoSlideInterval);
    startAutoSlide();
  }

  // ------------------- DRAG / SWIPE -------------------
  slides.forEach((slide, i) => {
    const slideImage = slide.querySelector("img");
    if (slideImage) {
      slideImage.addEventListener("dragstart", (e) => e.preventDefault());
    }

    // Touch events
    slide.addEventListener("touchstart", touchStart(i));
    slide.addEventListener("touchend", touchEnd);
    slide.addEventListener("touchmove", touchMove);

    // Mouse events
    slide.addEventListener("mousedown", touchStart(i));
    slide.addEventListener("mouseup", touchEnd);
    slide.addEventListener("mouseleave", touchEnd);
    slide.addEventListener("mousemove", touchMove);
  });

  function touchStart(indexParam) {
    return function(event) {
      isDragging = true;
      currentIndex = indexParam;
      startPos = getPositionX(event);
      slider.style.transition = "none";
      cancelAnimationFrame(animationID);
      animationID = requestAnimationFrame(animation);
      resetAutoSlide();
    };
  }

  function touchMove(event) {
    if (isDragging) {
      const currentPosition = getPositionX(event);
      currentTranslate = prevTranslate + currentPosition - startPos;
    }
  }

  function touchEnd() {
    cancelAnimationFrame(animationID);
    if (!isDragging) return;
    isDragging = false;
    const movedBy = currentTranslate - prevTranslate;

    if (movedBy < -100) {
      nextSlide();
    } else if (movedBy > 100) {
      prevSlide();
    } else {
      updateSlider();
    }

    currentTranslate = 0;
    prevTranslate = -index * slider.offsetWidth;
  }

  function getPositionX(event) {
    return event.type.includes("mouse")
      ? event.pageX
      : event.touches[0].clientX;
  }

  function animation() {
    if (isDragging) {
      slider.style.transform = `translateX(${currentTranslate}px)`;
      requestAnimationFrame(animation);
    }
  }

  // Initialize
  updateSlider();
  startAutoSlide();
});
</script>


{% schema %}
{
  "name": "Pre-order Promo",
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "label": "Heading",
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "for a limited time, take $20 off"
    },
    {
      "type": "color",
      "id": "content_bg",
      "label": "Content Background Color",
      "default": "#eafaf7"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Add to Calendar"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "Countdown End Date (YYYY-MM-DDTHH:MM:SS)",
      "default": "2025-10-10T23:59:59"
    },
    {
      "type": "range",
      "id": "padding-top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Slider Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "slide_img",
          "label": "Slide Image"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Pre-order Promo"
    }
  ]
}
{% endschema %}