{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}



{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  
  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mob }}px;
      padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    }
  }
{%- endstyle -%}

<style>
  .form-main-sec .page-width {
    display: flex;
    justify-content: space-between;
}
.form-main-sec .left-content-form,.form-main-sec form#ContactForm {
    width: 50%;
}
.form-main-sec form#ContactForm {
    background: rgba(241, 242, 244, 1);
    border-radius: 44px;
    padding: 50px;
}
 .form-main-sec form#ContactForm .contact__fields {
    display: block;
}
.form-main-sec form#ContactForm input, .form-main-sec form#ContactForm textarea {
    width: 100% !important;
    max-width: 100% !important;
    border-radius: 12px !important;
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
    background: rgba(255, 255, 255, 1);
    margin-bottom: 20px;
      height: 60px;
}
  .form-main-sec form#ContactForm textarea {
    height: 170px;
}
  .form-main-sec .field {
    flex-direction: column-reverse;
}
  .form-main-sec label.field__label {
    position: unset !important;
    float: unset;
    width: 100% !important;
    color: rgba(13, 24, 47, 1);
    font-size: 17px;
    font-weight: 500;
    line-height: 23.4px;
    text-align: left;
    margin-bottom: 8px;
}
.form-main-sec form#ContactForm .field::after,.form-main-sec form#ContactForm .field::before {
    display: none;
}
.left-content-form {
    padding-right: 150px;
}
.cstm-rich-text p {
    color: rgba(13, 24, 47, 1);
    font-size: 50px;
    font-weight: 500;
    line-height: 71.5px;
    text-align: left;
    margin: 0;
  text-transform:capitalize;
  margin-bottom:50px;
}
  .one-bar-cstm-contact {
    display: flex;
    align-items: flex-start;
    gap: 10px;
}
.one-bar-cstm-contact img {
    width: 24px;
}
.cstm-rich-text-scnd p {
    margin: 0;
    font-family: General Sans;
    font-size: 17px;
    font-weight: 500;
    line-height: 27.6px;
    text-align: left;
    color: rgba(77, 77, 77, 1);
}
  .inner-one-bar-cstm-contact img {
    width: 21px;
}
  .form-main-sec .contact__button {
    margin-top: 10px;
    margin-left: auto;
    display: flex;
    justify-content: flex-end;
}
.inner-one-bar-cstm-contact a {
    text-decoration: none;
}
.inner-one-bar-cstm-contact {
    display: flex;
    gap: 10px;
    align-items: flex-start;
}
.inner-one-bar-cstm-contact p {
    line-height: normal;
}
.one-bar-cstm-contact_second .cstm-rich-text-scnd {
    display: flex;
    align-items: center;
    gap: 10px;
}
.one-bar-cstm-contact_second {
    border-top: 1px solid rgba(204, 205, 206, 1);
    border-bottom: 1px solid rgba(204, 205, 206, 1);
    padding: 20px 0px;
    margin-top: 20px;
}
.one-bar-cstm-contact_second .inner-one-bar-cstm-contact:nth-child(1) {
    margin-bottom: 16px;
}
@media(max-width:1100px){
  .left-content-form {
    padding-right: 50px;
}
  .cstm-rich-text p {
    font-size: 40px;
    line-height: 51.5px;
    margin-bottom: 30px;
}
}
@media(max-width:768px){
  .left-content-form {
    padding-right: 0;
}
.form-main-sec .left-content-form, .form-main-sec form#ContactForm {
    width: 100%;
}
.form-main-sec .page-width {
    flex-direction: column;
    gap: 50px;
}
 .form-main-sec form#ContactForm {
    padding: 30px 20px;
} 
      .cstm-rich-text p {
        font-size: 34px;
        line-height: 39.5px;
        margin-bottom: 20px;
    }
  .one-bar-cstm-contact_second .cstm-rich-text-scnd {
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
}
.form-main-sec form#ContactForm input, .form-main-sec form#ContactForm textarea {
    height: 44px;
}
  .form-main-sec form#ContactForm textarea {
    height: 120px;
}
}
</style>




<div class="section-{{ section.id }}-padding form-main-sec">
  <div class="page-width">
 
    {%- liquid
      assign contact_form_class = 'isolate'
      if settings.animations_reveal_on_scroll
        assign contact_form_class = 'isolate scroll-trigger animate--slide-in'
      endif
    -%}
    {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}

       <div class="cstm-rich-text">{{ section.settings.titleheading }} </div>

      
      {%- if form.posted_successfully? -%}
        <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
          {% render 'icon-success' %}
          {{ 'templates.contact.form.post_success' | t }}
        </h2>
      {%- elsif form.errors -%}
        <div class="form__message">
          <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
            {% render 'icon-error' %}
            {{ 'templates.contact.form.error_heading' | t }}
          </h2>
        </div>
        <ul class="form-status-list caption-large" role="list">
          <li>
            <a href="#ContactForm-email" class="link">
              {{ form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email }}
            </a>
          </li>
        </ul>
      {%- endif -%}
      <div class="contact__fields">
        <div class="field">
          <input
            class="field__input"
            autocomplete="name"
            type="text"
            id="ContactForm-name"
            name="contact[{{ 'templates.contact.form.name' | t }}]"
            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            placeholder="Enter Your Name"
          >
          <label class="field__label" for="ContactForm-name">Your Name<span aria-hidden="true">*</span></label>
        </div>
        <div class="field ">
          <input
            autocomplete="email"
            type="email"
            id="ContactForm-email"
            class="field__input"
            name="contact[email]"
            spellcheck="false"
            autocapitalize="off"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            aria-required="true"
            {% if form.errors contains 'email' %}
              aria-invalid="true"
              aria-describedby="ContactForm-email-error"
            {% endif %}
            placeholder="Enter Your Email Adress"
          >
          <label class="field__label" for="ContactForm-email">
            Your Email<span aria-hidden="true">*</span></label>
          {%- if form.errors contains 'email' -%}
            <small class="contact__field-error" id="ContactForm-email-error">
              <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
              <span class="form__message">
                {%- render 'icon-error' -%}
                {{- form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email -}}
              </span>
            </small>
          {%- endif -%}
        </div>
     
      
      <div class="field">
        
<select name="contact[Choose Product]" id="product">
   <option value="Choose Product">Choose Product</option>
  <option value="Venty Fan">Venty Fan</option>
  <option selected value="Cozypod heater">Cozypod Heater</option>
  <option value="Venty Clip Fan">Venty Clip Fan</option>
  
  
</select>
<label class="field__label" for="ContactForm-name">Product<span aria-hidden="true">*</span></label>
      </div>
      <div class="field">
        <input
          type="tel"
          id="ContactForm-phone"
          class="field__input"
          autocomplete="tel"
          name="contact[{{ 'templates.contact.form.phone' | t }}]"
          pattern="[0-9\-]*"
          value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
          placeholder="Enter Your Order Number"
        >
        <label class="field__label" for="ContactForm-phone">Order Number<span aria-hidden="true">*</span></label>
      </div>
       </div>
      <div class="field">
        <textarea
          rows="10"
          id="ContactForm-body"
          class="text-area field__input"
          name="contact[{{ 'templates.contact.form.comment' | t }}]"
          placeholder="Enter Message"
        >
          {{- form.body -}}
        </textarea>
        <label class="form__label field__label" for="ContactForm-body">
          Your Message<span aria-hidden="true">*</span>
        </label>
      </div>
      <div class="contact__button">

  
        
        <button type="submit" class="btn-benefit-wrapper">
          Send message
             <span>
            <img src="https://cdn.shopify.com/s/files/1/0613/3297/9961/files/Right_25.png">
                      </span>
        </button>
      </div>
    {%- endform -%}
        
  </div>
</div>

{% schema %}
{
  "name": "Contact From New",
  "tag": "section",
  "class": "contact-from-new",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "richtext",
      "id": "titleheading",
      "label": "Title"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Content From New"
    }
  ]
}
{% endschema %}
