{% comment %}
  * Make sure you have the Flickity plugin installed and the proper license for this to function on your store
  * Plugin, licensing and documentation at https://flickity.metafizzy.co/
{% endcomment %}

{% assign cell_align = section.settings.cell_align %}
{% assign wrap_around = section.settings.wrap_around %}
{% assign img_width = section.settings.img_width | append: 'x' %}
{% assign autoplay_speed = section.settings.autoplay_speed | times: 1 %}
{% assign draggableslider = section.settings.draggableslider %}

<div class="new-slider-design flickity-section-{{ section.id }} flickity-index-slider section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="title-description-slider-new">
      {%- if section.settings.title != blank -%}
        <h2>{{ section.settings.title }}</h2>
      {%- endif %}
    </div>
  </div>
  <div
    class="flickity-section__carousel carousel-{{section.id }} text-center"
    data-flickity='
      {
          "cellAlign": "{{ cell_align }}",
          "pageDots": true,
         "autoPlay": {{ autoplay_speed }},
          "freeScroll": false,
          "contain": true,
          "draggable": {{ draggableslider }},
          "wrapAround": {{ wrap_around }}
      }
    '
  >
    {% for product in collection_main.products limit: collection_limit %}
      <div
        class="carousel__cell"
        style="width:{{ section.settings.cell_width }};margin-right:{{ section.settings.mr }}px"
      ></div>
    {% endfor %}
    {%- for block in section.blocks -%}
      <div
        class="carousel__cell meet-our-fans-car-cell"
        style="width:{{ section.settings.cell_width }};margin-right:{{ section.settings.mr }}px"
      >
        <div class="img-title-btn img-title-btn-new-design">
          <div class="img-main-new-slider-desing">
            {%- if block.settings.img1 -%}
              <img src="{{ block.settings.img1 | img_url: 'master' }}" alt="">
            {%- endif %}
          </div>
          {%- if block.settings.title1 -%}
            <h2>{{ block.settings.title1 }}</h2>
          {%- endif %}
        </div>
      </div>
    {%- endfor -%}
  </div>
  {%- for block in section.blocks -%}
    <div class="video-wrapper-slider">
      <div class="video-wrapper-slider-inner">
        {% if block.settings.video %}
          {{
            block.settings.video
            | video_tag:
              playsinline: true,
              muted: true,
              autoplay: true,
              loop: true,
              preload: 'metadata',
              class: 'ewrewrw'
          }}
        {% endif %}
        <div class="video-class-removed">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            focusable="false"
            class="icon icon-close closeburger"
            fill="none"
            viewBox="0 0 18 17"
          >
              <path d="M.865 15.978a.5.5 0 00.707.707l7.433-7.431 7.579 7.282a.501.501 0 00.846-.37.5.5 0 00-.153-.351L9.712 8.546l7.417-7.416a.5.5 0 10-.707-.708L8.991 7.853 1.413.573a.5.5 0 10-.693.72l7.563 7.268-7.418 7.417z" fill="currentColor">
            </path>
          </svg>
        </div>
      </div>
    </div>
  {%- endfor -%}
</div>

{% if section.settings.hidedots %}
  <style>
      .new-slider-design ol.flickity-page-dots {
        display: none;
    }
  </style>
{% endif %}

{% if section.settings.hidearrows %}
  <style>
      .new-slider-design button.flickity-button.flickity-prev-next-button.previous,
      .new-slider-design button.flickity-button.flickity-prev-next-button.next{
        display: none;
    }
  </style>
{% endif %}

<script>
  document.addEventListener('DOMContentLoaded', () => {
      const imgTitleBtns = document.querySelectorAll('.img-title-btn');
      const videoWrappers = document.querySelectorAll('.video-wrapper-slider');
      const videoClassRemoved = document.querySelectorAll('.video-class-removed');
      const videos = document.querySelectorAll('.video-wrapper-slider video');
      let isDragging = false;

      // Initialize Flickity
      const flkty = new Flickity('.flickity-section__carousel', {
          // Flickity options
          cellAlign: '{{ cell_align }}',
          pageDots: true,
          autoPlay: {{ autoplay_speed }},
          freeScroll: false,
          contain: true,
          draggable: {{ draggableslider }},
          wrapAround: {{ wrap_around }},
          on: {
              dragStart: function () {
                  isDragging = true;
              },
              dragEnd: function () {
                  isDragging = false;
              }
          }
      });

      imgTitleBtns.forEach((btn, index) => {
          btn.addEventListener('click', () => {
              if (isDragging) return; // Prevent click if dragging
              videoWrappers[index].classList.add('activated_VIDEO');
              document.body.classList.add('body-activated_VIDEO');

              // Play video from the start
              const video = videos[index];
              if (video) {
                  video.currentTime = 0; // Reset video to start
                  video.play(); // Play the video
              }
          });
      });

      videoClassRemoved.forEach((btn, index) => {
          btn.addEventListener('click', () => {
              if (isDragging) return; // Prevent click if dragging
              videoWrappers[index].classList.remove('activated_VIDEO');
              document.body.classList.remove('body-activated_VIDEO');

              // Pause the video
              const video = videos[index];
              if (video) {
                  video.pause(); // Pause the video
              }
          });
      });
  });
</script>


{% schema %}
{
    "name": "Slider Design",
    "settings": [

        {
