            "options": [
                {
                    "value": "40%",
                    "label": "Two"
                },
                {
                    "value": "30%",
                    "label": "Three"
                },
                {
                    "value": "26%",
                    "label": "Four"
                },
                {
                    "value": "20%",
                    "label": "Five"
                },
                {
                    "value": "16.6666667%",
                    "label": "Six"
                },
                {
                    "value": "12.5%",
                    "label": "Eight"
                }
            ],
            "default": "26%"
        },
      {
      "type": "checkbox",
      "id": "hidedots",
      "default": false,
      "label": "Check To Hide Dots Bar"
    },
      {
      "type": "checkbox",
      "id": "hidearrows",
      "default": false,
      "label": "Check To Hide Arrows"
    },
        {
