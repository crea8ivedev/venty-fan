document.addEventListener('DOMContentLoaded', function () {
  // Global popup ID
  const popupId = 'cozypodPopup';
  const popup = document.getElementById(popupId);
  
  if (!popup) return;

  // Collect all possible email inputs (shared across the site)
  const emailInputs = [
    document.getElementById('heroEmailInput'),
    document.getElementById('heroEmailInput1'),
    document.getElementById('emailUnlockInput')
  ];

  // Find the email input inside this specific popup
  const popupEmail = popup.querySelector('input[type="email"], #popupEmailInput');

  // Find all triggers that should open THIS popup
  const triggers = document.querySelectorAll('.cozypod-popup-trigger');

  triggers.forEach(trigger => {
    trigger.addEventListener('click', function (e) {
      // e.preventDefault(); // Optional: remove if buttons perform other actions

      let email = '';

      // Find the first filled email input on the page
      for (const input of emailInputs) {
        if (input && input.value.trim()) {
          email = input.value.trim();
          break;
        }
      }

      // If no email found, focus the first available input and stop
      if (!email) {
        const firstInput = emailInputs.find(input => input);
        if (firstInput) {
          firstInput.focus();
        }
        return;
      }

      // Prefill the email in the popup's input
      if (popupEmail) {
        popupEmail.value = email;
      }

      // Open popup
      popup.classList.add('is-open');
    });
  });

  // Close this popup when clicking overlay or close button
  popup.addEventListener('click', function (e) {
    if (
      e.target.classList.contains('cozypod-popup__overlay') ||
      e.target.classList.contains('cozypod-popup__close') ||
      e.target.closest('.cozypod-popup__close') 
    ) {
      popup.classList.remove('is-open');
    }
  });

  // Optional: close with Escape key
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && popup.classList.contains('is-open')) {
      popup.classList.remove('is-open');
    }
  });

});

</script>
