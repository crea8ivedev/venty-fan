<script> 

 // Function to handle tab switching and popup display
function openCity(evt, cityName) {
    var i, tabcontent, tablinks;

    // Hide all tab content
    tabcontent = document.getElementsByClassName("tabcontent");
    for (i = 0; i < tabcontent.length; i++) {
        tabcontent[i].style.display = "none";
    }

    // Remove 'active' class from all tab links
    tablinks = document.getElementsByClassName("tablinks");
    for (i = 0; i < tablinks.length; i++) {
        tablinks[i].className = tablinks[i].className.replace(" active", "");
    }

    // Show the clicked tab content and add 'active' class
    document.getElementById(cityName).style.display = "block";
    if (evt.currentTarget) {
        evt.currentTarget.className += " active";
    }

    // Display the popup
    document.getElementById("popupProduct").style.display = "block";
}

// Close popup functionality
function closePopup() {
    document.getElementById("popupProduct").style.display = "none";
}

// Close the popup when clicking outside
document.addEventListener("click", function (event) {
  const popup = document.getElementById("popupProduct");

  if (
    popup &&
    popup.style.display === "block" &&
    !popup.contains(event.target) &&
    !event.target.closest(".open-popup")
  ) {
    closePopup();
  }
});

// Add event listeners for dynamically opening the popup with the correct tab
document.querySelectorAll(".open-popup").forEach(tab => {
    tab.addEventListener("click", function () {
        // Extract the dynamic tab identifier from the clicked element
        const tabClass = Array.from(this.classList).find(cls =>
            cls.startsWith("tab")
        );
        if (tabClass) {
            const tabId = tabClass; // Example: "tab1", "tab2", etc.

            // Simulate a click event for `openCity` function
            openCity(
                { currentTarget: document.querySelector(`.tablinks[onclick*="${tabId}"]`) },
                tabId
            );
        }
    });
});


