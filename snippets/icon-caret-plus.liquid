<svg
  class="icon icon-caretplus"
  width="20"
  height="20"
  viewBox="0 0 20 20"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Horizontal line -->
  <line x1="4" y1="10" x2="16" y2="10"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"/>

  <!-- Vertical line (this disappears when open) -->
  <line class="caretplus-vertical"
        x1="10" y1="4" x2="10" y2="16"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"/>
</svg>
