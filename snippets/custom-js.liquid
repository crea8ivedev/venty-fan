<script>

  $(document).on("click", '.ChooseYourColor-1', function(e){
  // Get the input ID from the label's "for" attribute
  var inputId = $(this).attr('for');

  // Get the input element and its value (color)
  var inputElement = $('#' + inputId);
  var clickedColor = inputElement.val();

  console.log("You clicked:", clickedColor); // ✅ Shows the clicked color

  // Select the target container
  var $container = $('.product__info-container');

  // Remove all previously added color classes
  $container.removeClass('selected-black selected-white selected-red selected-blue selected-mint');

  // Add class dynamically based on clicked color
  $container.addClass('selected-' + clickedColor.toLowerCase());
});


</script>


<script>
function openCity(evt, cityName) {
  var i, tabcontent, tablinks;
  tabcontent = document.getElementsByClassName("tabcontent");
  for (i = 0; i < tabcontent.length; i++) {
    tabcontent[i].style.display = "none";
  }
  tablinks = document.getElementsByClassName("tablinks");
  for (i = 0; i < tablinks.length; i++) {
    tablinks[i].className = tablinks[i].className.replace(" active", "");
  }
  document.getElementById(cityName).style.display = "block";
  evt.currentTarget.className += " active";
}
</script>

