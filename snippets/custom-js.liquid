document.addEventListener("DOMContentLoaded", function() {
// Select all elements with the class 'li-menu-footer'
var menuFooters = document.querySelectorAll('.li-menu-footer');

// Iterate through each 'li-menu-footer' element
menuFooters.forEach(function(menuFooter) {
// Check if the current 'li-menu-footer' element contains a 'ul'
if (menuFooter.querySelector('ul')) {
// Add the class 'li-have-ul' to the 'li-menu-footer' element
menuFooter.classList.add('li-have-ul');
}
});

// Select all elements with the class 'li-have-ul'
const elements = document.querySelectorAll('.li-have-ul');

// Add a click event listener to each element
elements.forEach(element => {
element.addEventListener('click', () => {
// Toggle the 'li-triggered' class on the clicked element
element.classList.toggle('li-triggered');
});
});
});
 
document.addEventListener('DOMContentLoaded', (event) => {
const accordionBtns = document.querySelectorAll(".accordion-cstm");
accordionBtns.forEach((accordion) => {
accordion.onclick = function () {
this.classList.toggle("is-open");
let content = this.nextElementSibling;
content.classList.toggle("open"); // Add or remove 'open' class
if (content.style.maxHeight) {
// This is if the accordion is open
content.style.maxHeight = null;
} else {
// If the accordion is currently closed
content.style.maxHeight = content.scrollHeight + "px";
}
};
});
});

 

