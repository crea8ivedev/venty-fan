    "cst_ventry_features_jQT8Qi": {
      "type": "cst-ventry-features",
      "name": "Ventypro Features",
      "settings": {
        "text1": "Continuous  Power",
        "content1": "<p>With an upgraded 20,000mAh battery, Venty delivers uninterrupted airflow for days, up to 60+ hours per charge—perfect for camping trips, road trips, and long weekends away.</p>",
        "text2": "Powerful Airflow",
        "content2": "<p>Engineered to be 20% more powerful than the Original Venty, the Pro Series reaches airflow speeds up to 5 m/s and features five finely tuned speed settings for personalized comfort.</p>",
        "text3": "LED Ambient Light",
        "content3": "<p>The same signature ambient lighting as the Original Venty—now refined in a sleeker, more modern design.</p>",
        "text4": "Customized Oscillation",
        "content4": "<p>Choose between a focused 60° oscillation or a wider 90° sweep for perfectly tailored airflow.</p>",
        "text5": "12 Hr Smart Timer",
